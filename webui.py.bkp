@app.route('/udp/routers')
def list_udp_routers():
    """List all UDP routers."""
    try:
        names = config_manager.list_udp_routers()
        routers = []
        for name in names:
            r = config_manager.get_udp_router(name)
            routers.append(r if r else {'name': name})
        return render_template('udp/udp_routers.html', routers=routers)
    except Exception as e:
        flash(f'Error: {str(e)}', 'danger')
        return render_template('udp/udp_routers.html', routers=[])


@app.route('/udp/routers/create', methods=['GET', 'POST'])
def create_udp_router():
    """Create a UDP router."""
    try:
        udp_services = config_manager.list_udp_services()
    except Exception:
        udp_services = []
    if request.method == 'POST':
        name = request.form.get('name', '').strip()
        service = request.form.get('service', '').strip()
        entrypoints = _normalize_multi(request.form.getlist('entrypoints'))

        if not name or not service:
            flash('Name and service are required.', 'danger')
            return render_template(
                'udp/create_udp_router.html',
                form_data=request.form,
                udp_services=udp_services,
                entrypoint_options=UDP_ENTRYPOINT_OPTIONS,
                selected_entrypoints=entrypoints,
            )

        if not udp_services:
            flash('Create at least one UDP service before creating a UDP router.', 'danger')
            return render_template(
                'udp/create_udp_router.html',
                form_data=request.form,
                udp_services=udp_services,
                entrypoint_options=UDP_ENTRYPOINT_OPTIONS,
                selected_entrypoints=entrypoints,
            )

        if service not in udp_services:
            flash('Select a valid UDP service from the available options.', 'danger')
            return render_template(
                'udp/create_udp_router.html',
                form_data=request.form,
                udp_services=udp_services,
                entrypoint_options=UDP_ENTRYPOINT_OPTIONS,
                selected_entrypoints=entrypoints,
            )

        if not entrypoints:
            flash('Select at least one UDP entrypoint.', 'danger')
            return render_template(
                'udp/create_udp_router.html',
                form_data=request.form,
                udp_services=udp_services,
                entrypoint_options=UDP_ENTRYPOINT_OPTIONS,
                selected_entrypoints=entrypoints,
            )

        try:
            _validate_allowed_values(
                entrypoints,
                [opt['value'] for opt in UDP_ENTRYPOINT_OPTIONS],
                'UDP entrypoints',
            )
        except ValidationError as e:
            flash(str(e), 'danger')
            return render_template(
                'udp/create_udp_router.html',
                form_data=request.form,
                udp_services=udp_services,
                entrypoint_options=UDP_ENTRYPOINT_OPTIONS,
                selected_entrypoints=entrypoints,
            )

        try:
            config_manager.create_udp_router(name, service, entrypoints)
            flash(f'UDP Router "{name}" created!', 'success')
            return redirect(url_for('list_udp_routers'))
        except Exception as e:
            flash(f'Error: {str(e)}', 'danger')
            return render_template(
                'udp/create_udp_router.html',
                form_data=request.form,
                udp_services=udp_services,
                entrypoint_options=UDP_ENTRYPOINT_OPTIONS,
                selected_entrypoints=entrypoints,
            )

    return render_template(
        'udp/create_udp_router.html',
        form_data={},
        udp_services=udp_services,
        entrypoint_options=UDP_ENTRYPOINT_OPTIONS,
        selected_entrypoints=['udp'],
    )


@app.route('/udp/routers/delete/<name>', methods=['POST'])
@login_required
def delete_udp_router(name):
    """Delete a UDP router."""
    try:
        config_manager.delete_udp_router(name)
        flash(f'UDP Router "{name}" deleted.', 'success')
    except Exception as e:
        flash(f'Error: {str(e)}', 'danger')
    return redirect(url_for('list_udp_routers'))


@app.route('/udp/routers/edit/<name>', methods=['GET', 'POST'])
def edit_udp_router(name):
    """Edit an existing UDP router."""
    try:
        udp_services = config_manager.list_udp_services()
    except Exception:
        udp_services = []

    existing = config_manager.get_udp_router(name)
    if not existing:
        flash(f'UDP Router "{name}" not found.', 'warning')
        return redirect(url_for('list_udp_routers'))

    if request.method == 'POST':
        service = request.form.get('service', '').strip()
        entrypoints = _normalize_multi(request.form.getlist('entrypoints'))

        if not service:
            flash('Service is required.', 'danger')
            return render_template(
                'udp/edit_udp_router.html',
                router_name=name,
                form_data=request.form,
                udp_services=udp_services,
                entrypoint_options=UDP_ENTRYPOINT_OPTIONS,
                selected_entrypoints=entrypoints,
            )

        if service not in udp_services:
            flash('Select a valid UDP service from the available options.', 'danger')
            return render_template(
                'udp/edit_udp_router.html',
                router_name=name,
                form_data=request.form,
                udp_services=udp_services,
                entrypoint_options=UDP_ENTRYPOINT_OPTIONS,
                selected_entrypoints=entrypoints,
            )

        if not entrypoints:
            flash('Select at least one UDP entrypoint.', 'danger')
            return render_template(
                'udp/edit_udp_router.html',
                router_name=name,
                form_data=request.form,
                udp_services=udp_services,
                entrypoint_options=UDP_ENTRYPOINT_OPTIONS,
                selected_entrypoints=entrypoints,
            )

        try:
            _validate_allowed_values(
                entrypoints,
                [opt['value'] for opt in UDP_ENTRYPOINT_OPTIONS],
                'UDP entrypoints',
            )
        except ValidationError as e:
            flash(str(e), 'danger')
            return render_template(
                'udp/edit_udp_router.html',
                router_name=name,
                form_data=request.form,
                udp_services=udp_services,
                entrypoint_options=UDP_ENTRYPOINT_OPTIONS,
                selected_entrypoints=entrypoints,
            )

        try:
            config_manager.create_udp_router(name, service, entrypoints)
            flash(f'UDP Router "{name}" updated!', 'success')
            return redirect(url_for('list_udp_routers'))
        except Exception as e:
            flash(f'Error: {str(e)}', 'danger')
            return render_template(
                'udp/edit_udp_router.html',
                router_name=name,
                form_data=request.form,
                udp_services=udp_services,
                entrypoint_options=UDP_ENTRYPOINT_OPTIONS,
                selected_entrypoints=entrypoints,
            )

    svc = existing.get('service', '') if isinstance(existing, dict) else ''
    eps = existing.get('entrypoints', []) if isinstance(existing, dict) else []
    form_data = {'service': svc, 'entrypoints': eps}
    return render_template(
        'udp/edit_udp_router.html',
        router_name=name,
        form_data=form_data,
        udp_services=udp_services,
        entrypoint_options=UDP_ENTRYPOINT_OPTIONS,
        selected_entrypoints=eps,
    )


