# Sync to the DB-active connection (may differ from env var)
def _reinit_etcd(url: str):
    """Reinitialise the global etcd client and config manager."""
    global etcd_url, etcd_client, config_manager
    etcd_url = url
    etcd_client = ETCDClient(url)
    config_manager = ConfigManager(etcd_client)

_active = _auth_db.get_active_connection()
if _active and _active['url'] != etcd_url:
    _reinit_etcd(_active['url'])


# ─── Auth helpers ─────────────────────────────────────────────

def login_required(f):
    """Decorator: redirect to /login if not authenticated."""
    @wraps(f)
    def decorated(*args, **kwargs):
        if 'username' not in session:
            return redirect(url_for('login'))
        if session.get('must_change_password') and request.endpoint != 'change_password':
            return redirect(url_for('change_password'))
        return f(*args, **kwargs)
    return decorated


@app.before_request
def check_auth_and_sync():
    """Enforce login and ensure the global etcd client matches active connection."""
    open_eps = {'login', 'logout', 'static', 'health'}
    if request.endpoint in open_eps:
        return

    # Auth gate
    if 'username' not in session:
        return redirect(url_for('login'))

    # Force password change on first login
    if session.get('must_change_password') and request.endpoint != 'change_password':
        return redirect(url_for('change_password'))

    # Sync active etcd connection
    try:
        active = _auth_db.get_active_connection()
        if active and active['url'] != etcd_url:
            _reinit_etcd(active['url'])
    except Exception:
        pass


@app.context_processor
def inject_nav_status():
    """Inject global status + user info used by base navigation."""
    try:
        nav_etcd_healthy = etcd_client.health_check()
    except Exception:
        nav_etcd_healthy = False
    try:
        active_conn = _auth_db.get_active_connection()
        nav_conn_name = active_conn['name'] if active_conn else 'Default'
        nav_conn_url  = active_conn['url']  if active_conn else etcd_url
    except Exception:
        nav_conn_name = 'Default'
        nav_conn_url  = etcd_url

    endpoint = request.endpoint or ''
    meta = ENDPOINT_META.get(endpoint, {})
    auto_section = meta.get('section')
    auto_title = meta.get('title') or endpoint.replace('_', ' ').title() if endpoint else 'Dashboard'

    return {
        'nav_etcd_healthy': nav_etcd_healthy,
        'nav_conn_name':    nav_conn_name,
        'nav_conn_url':     nav_conn_url,
        'current_user':     session.get('username', ''),
        'auto_breadcrumb_section': auto_section,
        'auto_breadcrumb_title': auto_title,
    }


def _validate_etcd_url(url: str) -> tuple[bool, str]:
    """Validate etcd URL shape with clear message for users."""
    if not url:
        return False, 'etcd URL is required.'

    parsed = urlparse(url)
    if parsed.scheme not in {'http', 'https'}:
        return False, 'etcd URL must start with http:// or https://'
    if not parsed.netloc:
        return False, 'etcd URL must include host and port (e.g. http://10.0.0.1:2379)'

    return True, ''


def _extract_hostname_from_rule(rule: str) -> str:
    """Extract hostname from Host(`example.com`) rule."""
    if not rule:
        return ''

    match = re.search(r'Host\(`([^`]+)`\)', rule)
    if match:
        return match.group(1)

    return ''


def _parse_priority(value: str) -> int:
    """Parse priority with safe default."""
    try:
        return int(value)
    except (TypeError, ValueError):
        return 0


def _parse_int(value: str, default: int = 0) -> int:
    """Parse integer with safe default."""
    try:
        return int(value)
    except (TypeError, ValueError):
        return default


def _parse_csv(value: str) -> list[str]:
    """Parse comma-separated values into a clean list."""
    if not value:
        return []
    return [item.strip() for item in value.split(',') if item.strip()]


def _tls_cert_resolver_value(tls: object) -> str:
    """Extract TLS cert resolver from object/dict for compatibility."""
    if not tls:
        return ''
    if isinstance(tls, dict):
        return tls.get('cert_resolver') or tls.get('certresolver') or tls.get('certResolver') or ''
    return getattr(tls, 'cert_resolver', '') or getattr(tls, 'certresolver', '') or ''


