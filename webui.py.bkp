@app.route('/serversTransports')
def list_servers_transports():
    """List all HTTP serversTransports."""
    try:
        names = config_manager.list_servers_transports()
        transports = []
        for name in names:
            t = config_manager.get_servers_transport(name)
            transports.append(t if t else ServersTransport(name=name))
        return render_template('http/servers_transports.html', transports=transports)
    except Exception as e:
        flash(f'Error: {str(e)}', 'danger')
        return render_template('http/servers_transports.html', transports=[])


@app.route('/serversTransports/create', methods=['GET', 'POST'])
def create_servers_transport():
    """Create an HTTP serversTransport."""
    if request.method == 'POST':
        name = request.form.get('name', '').strip()
        server_name = request.form.get('server_name', '').strip()
        insecure = request.form.get('insecure_skip_verify') == 'on'
        root_cas = _parse_csv(request.form.get('root_cas', ''))
        max_idle = _parse_int(request.form.get('max_idle_conns', ''), 0)
        disable_h2 = request.form.get('disable_http2') == 'on'
        peer_cert_uri = request.form.get('peer_cert_uri', '').strip()

        if not name:
            flash('Name is required.', 'danger')
            return render_template('http/create_servers_transport.html', form_data=request.form)

        try:
            transport = ServersTransport(
                name=name, server_name=server_name,
                insecure_skip_verify=insecure, root_cas=root_cas,
                max_idle_conns_per_host=max_idle, disable_http2=disable_h2,
                peer_cert_uri=peer_cert_uri,
            )
            config_manager.create_servers_transport(transport)
            flash(f'ServersTransport "{name}" created!', 'success')
            return redirect(url_for('list_servers_transports'))
        except Exception as e:
            flash(f'Error: {str(e)}', 'danger')
            return render_template('http/create_servers_transport.html', form_data=request.form)

    return render_template('http/create_servers_transport.html', form_data={})


@app.route('/serversTransports/delete/<name>', methods=['POST'])
def delete_servers_transport(name):
    """Delete an HTTP serversTransport."""
    try:
        config_manager.delete_servers_transport(name)
        flash(f'ServersTransport "{name}" deleted.', 'success')
    except Exception as e:
        flash(f'Error: {str(e)}', 'danger')
    return redirect(url_for('list_servers_transports'))


@app.route('/serversTransports/edit/<name>', methods=['GET', 'POST'])
def edit_servers_transport(name):
    """Edit an existing HTTP serversTransport."""
    existing = config_manager.get_servers_transport(name)
    if not existing:
        flash(f'ServersTransport "{name}" not found.', 'warning')
        return redirect(url_for('list_servers_transports'))

    if request.method == 'POST':
        server_name = request.form.get('server_name', '').strip()
        insecure = request.form.get('insecure_skip_verify') == 'on'
        root_cas = _parse_csv(request.form.get('root_cas', ''))
        max_idle = _parse_int(request.form.get('max_idle_conns', ''), 0)
        disable_h2 = request.form.get('disable_http2') == 'on'
        peer_cert_uri = request.form.get('peer_cert_uri', '').strip()

        try:
            transport = ServersTransport(
                name=name, server_name=server_name,
                insecure_skip_verify=insecure, root_cas=root_cas,
                max_idle_conns_per_host=max_idle, disable_http2=disable_h2,
                peer_cert_uri=peer_cert_uri,
            )
            config_manager.update_servers_transport(transport)
            flash(f'ServersTransport "{name}" updated!', 'success')
            return redirect(url_for('list_servers_transports'))
        except Exception as e:
            flash(f'Error: {str(e)}', 'danger')
            return render_template('http/edit_servers_transport.html', transport_name=name, form_data=request.form)

    form_data = {
        'server_name': existing.server_name,
        'insecure_skip_verify': existing.insecure_skip_verify,
        'root_cas': ', '.join(existing.root_cas),
        'max_idle_conns': existing.max_idle_conns_per_host,
        'disable_http2': existing.disable_http2,
        'peer_cert_uri': existing.peer_cert_uri,
    }
    return render_template('http/edit_servers_transport.html', transport_name=name, form_data=form_data)


