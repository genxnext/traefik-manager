@app.route('/help')
def help_page():
    """Comprehensive user help page."""
    return render_template('common/help.html')


@app.route('/config/export')
def export_config():
    """Show export options page."""
    return render_template('config/export_config.html')


@app.route('/config/export/download')
def export_config_download():
    """Download Traefik config as JSON (routers / services / middlewares)."""
    try:
        exported = config_manager.export_full_config()
        payload = json.dumps(exported, indent=2, default=_json_default_serializer)
        response = make_response(payload)
        response.headers['Content-Type'] = 'application/json'
        response.headers['Content-Disposition'] = 'attachment; filename=traefik-config-export.json'
        return response
    except Exception as e:
        flash(f'Error exporting config: {str(e)}', 'danger')
        return redirect(url_for('export_config'))


@app.route('/config/export/backup')
def export_full_backup():
    """Download full backup: all etcd KVs under /traefik/ + connection profiles (no user accounts)."""
    try:
        # Get every key stored under /traefik/
        all_kvs = etcd_client.get_prefix('/traefik/')

        # Get connection profiles (no passwords — connections only store url/name/description)
        conns = _auth_db.list_connections()

        backup = {
            'version': '1.0',
            'exported_at': datetime.utcnow().isoformat() + 'Z',
            'etcd_prefix': '/traefik/',
            'etcd_kvs': all_kvs,
            'connections': [
                {
                    'name': c['name'],
                    'url': c['url'],
                    'description': c.get('description', ''),
                }
                for c in conns
            ],
        }

        payload = json.dumps(backup, indent=2)
        ts = datetime.utcnow().strftime('%Y%m%d-%H%M%S')
        response = make_response(payload)
        response.headers['Content-Type'] = 'application/json'
        response.headers['Content-Disposition'] = f'attachment; filename=traefik-backup-{ts}.json'
        return response
    except Exception as e:
        flash(f'Backup export failed: {str(e)}', 'danger')
        return redirect(url_for('export_config'))


@app.route('/config/import/backup', methods=['POST'])
def import_full_backup():
    """Restore a full backup: write etcd KVs and optionally add connection profiles."""
    backup_file = request.files.get('backup_file')
    if not backup_file or not backup_file.filename:
        flash('No backup file selected.', 'danger')
        return redirect(url_for('import_config'))

    try:
        raw = backup_file.read().decode('utf-8')
        backup = json.loads(raw)
    except (UnicodeDecodeError, json.JSONDecodeError) as e:
        flash(f'Invalid backup file: {str(e)}', 'danger')
        return redirect(url_for('import_config'))

    if not isinstance(backup, dict) or 'etcd_kvs' not in backup:
        flash('File does not look like a Traefik Manager backup (missing etcd_kvs key).', 'danger')
        return redirect(url_for('import_config'))

    try:
        kvs = backup.get('etcd_kvs', {})
        kv_ok = kv_fail = 0
        for key, value in kvs.items():
            try:
                if etcd_client.put(str(key), str(value)):
                    kv_ok += 1
                else:
                    kv_fail += 1
            except Exception:
                kv_fail += 1

        conn_ok = conn_skip = 0
        import_connections = request.form.get('import_connections') == 'on'
        if import_connections:
            existing_urls = {c['url'] for c in _auth_db.list_connections()}
            for conn in backup.get('connections', []):
                url = (conn.get('url') or '').strip()
                name = (conn.get('name') or url).strip()
                if url and url not in existing_urls:
                    try:
                        _auth_db.add_connection(name, url, conn.get('description', ''))
                        conn_ok += 1
                    except Exception:
                        pass
                else:
                    conn_skip += 1

        cat = 'success' if kv_fail == 0 else 'warning'
        parts = [f'{kv_ok} etcd key(s) restored']
        if kv_fail:
            parts.append(f'{kv_fail} failed')
        if import_connections:
            parts.append(f'{conn_ok} connection(s) added, {conn_skip} skipped')
        flash('Backup import complete — ' + ', '.join(parts) + '.', cat)
        return redirect(url_for('index'))

    except Exception as e:
        flash(f'Backup import failed: {str(e)}', 'danger')
        return redirect(url_for('import_config'))


@app.route('/config/import', methods=['GET', 'POST'])
def import_config():
    """Import configuration from JSON payload (routers and/or services)."""
    if request.method == 'POST':
        config_json = request.form.get('config_json', '').strip()
        merge = request.form.get('merge') == 'on'
        import_type = request.form.get('import_type', 'routers').strip()

        if not config_json:
            flash('JSON configuration is required.', 'danger')
            return render_template('config/import_config.html', form_data=request.form)

        try:
            data = json.loads(config_json)
        except json.JSONDecodeError as e:
            flash(f'Invalid JSON: {str(e)}', 'danger')
            return render_template('config/import_config.html', form_data=request.form)

        try:
            # ---- HTTP Routers ----
            if import_type == 'routers':
                routers_data = None
                if isinstance(data, dict):
                    if isinstance(data.get('http'), dict) and isinstance(data['http'].get('routers'), list):
                        routers_data = data['http']['routers']
                    elif isinstance(data.get('routers'), list):
                        routers_data = data['routers']
                elif isinstance(data, list):
                    routers_data = data

                if routers_data is None:
                    flash('No routers list found. Expected data["http"]["routers"] or data["routers"] or a plain list.', 'danger')
                    return render_template('config/import_config.html', form_data=request.form)

                for idx, router_item in enumerate(routers_data, start=1):
                    if not isinstance(router_item, dict):
                        flash(f'Invalid router at index {idx}: expected an object/dict.', 'danger')
                        return render_template('config/import_config.html', form_data=request.form)
                    missing = [f for f in ('name', 'rule', 'service') if not router_item.get(f)]
                    if missing:
                        flash(f'Router at index {idx} missing: {", ".join(missing)}.', 'danger')
                        return render_template('config/import_config.html', form_data=request.form)

                success_count, failure_count = config_manager.import_routers(routers_data, merge=merge)
                total = len(routers_data)
                cat = 'success' if failure_count == 0 else 'warning'
                flash(f'Routers import: {success_count} succeeded, {failure_count} failed (total {total}).', cat)
                return redirect(url_for('list_routers'))

            # ---- HTTP Services ----
            elif import_type == 'services':
                services_data = None
                if isinstance(data, dict):
                    if isinstance(data.get('http'), dict) and isinstance(data['http'].get('services'), list):
                        services_data = data['http']['services']
                    elif isinstance(data.get('services'), list):
                        services_data = data['services']
                elif isinstance(data, list):
                    services_data = data

                if services_data is None:
                    flash('No services list found. Provide a list of {"name":..., "url":...} objects.', 'danger')
                    return render_template('config/import_config.html', form_data=request.form)

                success_count = failure_count = 0
                for item in services_data:
                    if not isinstance(item, dict):
                        failure_count += 1
                        continue
                    svc_name = item.get('name', '').strip()
                    svc_url = item.get('url', item.get('primary_url', '')).strip()
                    if not svc_name or not svc_url:
                        failure_count += 1
                        continue
                    try:
                        config_manager.create_simple_service(svc_name, svc_url)
                        success_count += 1
                    except Exception:
                        failure_count += 1

                cat = 'success' if failure_count == 0 else 'warning'
                flash(f'Services import: {success_count} succeeded, {failure_count} failed.', cat)
                return redirect(url_for('list_services'))

            else:
                flash(f'Unknown import type: {import_type}', 'danger')
                return render_template('config/import_config.html', form_data=request.form)

        except Exception as e:
            flash(f'Error during import: {str(e)}', 'danger')
            return render_template('config/import_config.html', form_data=request.form)

    return render_template('config/import_config.html', form_data={'merge': 'on', 'import_type': 'routers'})


@app.route('/routers')
def list_routers():
    """List all routers"""
    try:
        routers = config_manager.list_routers()
        return render_template('http/routers.html', routers=routers)
    except Exception as e:
        flash(f'Error loading routers: {str(e)}', 'danger')
        return render_template('http/routers.html', routers=[])


@app.route('/routers/create', methods=['GET', 'POST'])
def create_router():
    """Create new router"""
    def _render_create_router(form_data=None, selected_middlewares=None):
        try:
            services = config_manager.list_services()
            middlewares = config_manager.list_middlewares()
            tls_options = config_manager.list_tls_options()
        except Exception as e:
            flash(f'Error loading form data: {str(e)}', 'danger')
            services = []
            middlewares = []
            tls_options = []

        if selected_middlewares is None:
            selected_middlewares = _normalize_multi(_form_values(form_data or {}, 'middlewares'))

        selected_entrypoints = _normalize_multi(_form_values(form_data or {}, 'entrypoints'))
        if not selected_entrypoints:
            selected_entrypoints = ['websecure']

        return render_template(
            'http/create_router.html',
            services=services,
            middlewares=middlewares,
            tls_options=tls_options,
            cert_resolvers=_available_cert_resolvers(),
            entrypoint_options=HTTP_ENTRYPOINT_OPTIONS,
            form_data=form_data or {},
            selected_middlewares=selected_middlewares,
            selected_entrypoints=selected_entrypoints,
        )

    if request.method == 'POST':
        try:
            # Get form data
            name = request.form.get('name', '').strip()
            hostname = request.form.get('hostname', '').strip()
            rule = request.form.get('rule', '').strip()
            service = request.form.get('service', '').strip()
            entrypoints = _normalize_multi(request.form.getlist('entrypoints'))
            middlewares_selected = _normalize_multi(request.form.getlist('middlewares'))
            enable_tls = request.form.get('enable_tls') == 'on'
            cert_resolver = request.form.get('cert_resolver', 'letsencrypt').strip()
            tls_options_value = request.form.get('tls_options', '').strip()
            priority = _parse_priority(request.form.get('priority', '0'))

            services = config_manager.list_services()
            middlewares_available = config_manager.list_middlewares()
            tls_options_available = config_manager.list_tls_options()
            cert_resolvers_available = _available_cert_resolvers()

            if not services:
                flash('Create at least one HTTP service before creating a router.', 'danger')
                return _render_create_router(request.form, selected_middlewares=middlewares_selected)

            if service not in services:
                flash('Select a valid HTTP service from the available options.', 'danger')
                return _render_create_router(request.form, selected_middlewares=middlewares_selected)

            if not entrypoints:
                flash('Select at least one entrypoint.', 'danger')
                return _render_create_router(request.form, selected_middlewares=middlewares_selected)

            _validate_allowed_values(
                entrypoints,
                [opt['value'] for opt in HTTP_ENTRYPOINT_OPTIONS],
                'HTTP entrypoints',
            )

            middlewares = middlewares_selected
            _validate_allowed_values(middlewares, middlewares_available, 'HTTP middlewares')
            
            # Build rule (advanced mode) or fallback to hostname (simple mode)
            if rule:
                effective_rule = rule
            elif hostname:
                effective_rule = f"Host(`{hostname}`)"
            else:
                flash('Provide either a hostname or a rule.', 'danger')
                return _render_create_router(request.form, selected_middlewares=middlewares_selected)
            
            # Build TLS config
            tls = None
            if enable_tls:
                if cert_resolver and cert_resolver not in cert_resolvers_available:
                    flash('Select a valid TLS certificate resolver.', 'danger')
                    return _render_create_router(request.form, selected_middlewares=middlewares_selected)
                if tls_options_value and tls_options_value not in tls_options_available:
                    flash('Select a valid TLS options profile.', 'danger')
                    return _render_create_router(request.form, selected_middlewares=middlewares_selected)
                tls = TLSConfig(cert_resolver=cert_resolver)
                tls.options = tls_options_value
            
            # Create router object
            router = Router(
                name=name,
                rule=effective_rule,
                service=service,
                entrypoints=entrypoints,
                middlewares=middlewares,
                priority=priority,
                tls=tls
            )
            
            # Create router via config manager
            config_manager.create_router(router)
            
            flash(f'Router "{name}" created successfully!', 'success')
            return redirect(url_for('list_routers'))
            
        except ValidationError as e:
            flash(f'Validation error: {str(e)}', 'danger')
            return _render_create_router(request.form, selected_middlewares=request.form.getlist('middlewares'))
        except Exception as e:
            flash(f'Error creating router: {str(e)}', 'danger')
            return _render_create_router(request.form, selected_middlewares=request.form.getlist('middlewares'))
    
    # GET request - show form
    return _render_create_router({})


@app.route('/routers/delete/<name>', methods=['POST'])
def delete_router(name):
    """Delete router"""
    try:
        config_manager.delete_router(name)
        flash(f'Router "{name}" deleted successfully!', 'success')
    except Exception as e:
        flash(f'Error deleting router: {str(e)}', 'danger')
    
    return redirect(url_for('list_routers'))


@app.route('/routers/edit/<name>', methods=['GET', 'POST'])
def edit_router(name):
    """Edit existing router"""
    try:
        services = config_manager.list_services()
        middlewares = config_manager.list_middlewares()
        tls_options = config_manager.list_tls_options()
    except Exception as e:
        flash(f'Error loading form data: {str(e)}', 'danger')
        services = []
        middlewares = []
        tls_options = []

    existing_router = config_manager.get_router(name)
    if not existing_router:
        flash(f'Router "{name}" not found.', 'warning')
        return redirect(url_for('list_routers'))

    if request.method == 'POST':
        try:
            hostname = request.form.get('hostname', '').strip()
            rule = request.form.get('rule', '').strip()
            service = request.form.get('service', '').strip()
            entrypoints = _normalize_multi(request.form.getlist('entrypoints'))
            middlewares_selected = _normalize_multi(request.form.getlist('middlewares'))
            enable_tls = request.form.get('enable_tls') == 'on'
            cert_resolver = request.form.get('cert_resolver', 'letsencrypt').strip()
            tls_options_value = request.form.get('tls_options', '').strip()
            priority = _parse_priority(request.form.get('priority', '0'))

            cert_resolvers_available = _available_cert_resolvers()

            if not services:
                flash('Create at least one HTTP service before editing this router.', 'danger')
                return render_template(
                    'http/edit_router.html',
                    router=existing_router,
                    services=services,
                    middlewares=middlewares,
                    tls_options=tls_options,
                    cert_resolvers=cert_resolvers_available,
                    entrypoint_options=HTTP_ENTRYPOINT_OPTIONS,
                    form_data=request.form,
                    selected_middlewares=middlewares_selected,
                    selected_entrypoints=entrypoints,
                )

            if service not in services:
                flash('Select a valid HTTP service from the available options.', 'danger')
                return render_template(
                    'http/edit_router.html',
                    router=existing_router,
                    services=services,
                    middlewares=middlewares,
                    tls_options=tls_options,
                    cert_resolvers=cert_resolvers_available,
                    entrypoint_options=HTTP_ENTRYPOINT_OPTIONS,
                    form_data=request.form,
                    selected_middlewares=middlewares_selected,
                    selected_entrypoints=entrypoints,
                )

            if not hostname and not rule:
                flash('Provide either a hostname or a rule.', 'danger')
                return render_template(
                    'http/edit_router.html',
                    router=existing_router,
                    services=services,
                    middlewares=middlewares,
                    tls_options=tls_options,
                    cert_resolvers=cert_resolvers_available,
                    entrypoint_options=HTTP_ENTRYPOINT_OPTIONS,
                    form_data=request.form,
                    selected_middlewares=middlewares_selected,
                    selected_entrypoints=entrypoints,
                )

            if not entrypoints:
                flash('Select at least one entrypoint.', 'danger')
                return render_template(
                    'http/edit_router.html',
                    router=existing_router,
                    services=services,
                    middlewares=middlewares,
                    tls_options=tls_options,
                    cert_resolvers=cert_resolvers_available,
                    entrypoint_options=HTTP_ENTRYPOINT_OPTIONS,
                    form_data=request.form,
                    selected_middlewares=middlewares_selected,
                    selected_entrypoints=entrypoints,
                )

            _validate_allowed_values(
                entrypoints,
                [opt['value'] for opt in HTTP_ENTRYPOINT_OPTIONS],
                'HTTP entrypoints',
            )

            middlewares_list = middlewares_selected
            _validate_allowed_values(middlewares_list, middlewares, 'HTTP middlewares')
            if rule:
                effective_rule = rule
            else:
                effective_rule = f"Host(`{hostname}`)"

            tls = None
            if enable_tls:
                if cert_resolver and cert_resolver not in cert_resolvers_available:
                    flash('Select a valid TLS certificate resolver.', 'danger')
                    return render_template(
                        'http/edit_router.html',
                        router=existing_router,
                        services=services,
                        middlewares=middlewares,
                        tls_options=tls_options,
                        cert_resolvers=cert_resolvers_available,
                        entrypoint_options=HTTP_ENTRYPOINT_OPTIONS,
                        form_data=request.form,
                        selected_middlewares=middlewares_selected,
                        selected_entrypoints=entrypoints,
                    )
                if tls_options_value and tls_options_value not in tls_options:
                    flash('Select a valid TLS options profile.', 'danger')
                    return render_template(
                        'http/edit_router.html',
                        router=existing_router,
                        services=services,
                        middlewares=middlewares,
                        tls_options=tls_options,
                        cert_resolvers=cert_resolvers_available,
                        entrypoint_options=HTTP_ENTRYPOINT_OPTIONS,
                        form_data=request.form,
                        selected_middlewares=middlewares_selected,
                        selected_entrypoints=entrypoints,
                    )
                tls = TLSConfig(cert_resolver=cert_resolver)
                tls.options = tls_options_value

            router = Router(
                name=name,
                rule=effective_rule,
                service=service,
                entrypoints=entrypoints,
                middlewares=middlewares_list,
                priority=priority,
                tls=tls
            )

            config_manager.update_router(router)
            flash(f'Router "{name}" updated successfully!', 'success')
            return redirect(url_for('list_routers'))

        except ValidationError as e:
            flash(f'Validation error: {str(e)}', 'danger')
            return render_template(
                'http/edit_router.html',
                router=existing_router,
                services=services,
                middlewares=middlewares,
                tls_options=tls_options,
                cert_resolvers=_available_cert_resolvers(),
                entrypoint_options=HTTP_ENTRYPOINT_OPTIONS,
                form_data=request.form,
                selected_middlewares=middlewares_selected,
                selected_entrypoints=entrypoints,
            )
        except Exception as e:
            flash(f'Error updating router: {str(e)}', 'danger')
            return render_template(
                'http/edit_router.html',
                router=existing_router,
                services=services,
                middlewares=middlewares,
                tls_options=tls_options,
                cert_resolvers=_available_cert_resolvers(),
                entrypoint_options=HTTP_ENTRYPOINT_OPTIONS,
                form_data=request.form,
                selected_middlewares=middlewares_selected,
                selected_entrypoints=entrypoints,
            )

    form_data = {
        'hostname': _extract_hostname_from_rule(existing_router.rule),
        'rule': existing_router.rule,
        'service': existing_router.service,
        'entrypoints': existing_router.entrypoints,
        'enable_tls': bool(existing_router.tls),
        'cert_resolver': _tls_cert_resolver_value(existing_router.tls) if existing_router.tls else 'letsencrypt',
        'tls_options': existing_router.tls.options if existing_router.tls else '',
        'priority': existing_router.priority
    }

    return render_template(
        'http/edit_router.html',
        router=existing_router,
        services=services,
        middlewares=middlewares,
        tls_options=tls_options,
        cert_resolvers=_available_cert_resolvers(),
        entrypoint_options=HTTP_ENTRYPOINT_OPTIONS,
        form_data=form_data,
        selected_middlewares=existing_router.middlewares,
        selected_entrypoints=existing_router.entrypoints,
    )


@app.route('/services')
def list_services():
    """List all services"""
    try:
        services = config_manager.list_services()
        service_urls = {}
        for svc_name in services:
            key = f'traefik/http/services/{svc_name}/loadbalancer/servers/0/url'
            service_urls[svc_name] = etcd_client.get(key) or ''
        return render_template('http/services.html', services=services, service_urls=service_urls)
    except Exception as e:
        flash(f'Error loading services: {str(e)}', 'danger')
        return render_template('http/services.html', services=[], service_urls={})


@app.route('/services/<name>')
def service_detail(name):
    """Show raw etcd service keys and parsed primary URL."""
    prefix = f'traefik/http/services/{name}/'
    try:
        raw_kvs = etcd_client.get_prefix(prefix)
        parsed_primary_url = raw_kvs.get(f'{prefix}loadbalancer/servers/0/url', '')

        if not raw_kvs:
            flash(f'Service "{name}" not found.', 'warning')

        return render_template(
            'http/service_detail.html',
            service_name=name,
            raw_kvs=sorted(raw_kvs.items()),
            parsed_primary_url=parsed_primary_url,
        )
    except Exception as e:
        flash(f'Error loading service detail: {str(e)}', 'danger')
        return render_template(
            'http/service_detail.html',
            service_name=name,
            raw_kvs=[],
            parsed_primary_url='',
        )


@app.route('/services/edit/<name>', methods=['GET', 'POST'])
def edit_service(name):
    """Edit an existing simple loadbalancer service URL."""
    key = f'traefik/http/services/{name}/loadbalancer/servers/0/url'

    if request.method == 'POST':
        url = request.form.get('url', '').strip()

        if not url:
            flash('Backend URL is required.', 'danger')
            return render_template('http/edit_service.html', service_name=name, form_data=request.form)

        try:
            success = config_manager.create_simple_service(name, url)
            if success:
                flash(f'Service "{name}" updated successfully!', 'success')
                return redirect(url_for('list_services'))

            flash(f'Failed to update service "{name}".', 'danger')
            return render_template('http/edit_service.html', service_name=name, form_data=request.form)
        except Exception as e:
            flash(f'Error updating service: {str(e)}', 'danger')
            return render_template('http/edit_service.html', service_name=name, form_data=request.form)

    existing_url = etcd_client.get(key)
    if not existing_url:
        flash(f'Service "{name}" not found or has no simple URL configured.', 'warning')
        return redirect(url_for('list_services'))

    return render_template('http/edit_service.html', service_name=name, form_data={'url': existing_url})


@app.route('/services/create', methods=['GET', 'POST'])
def create_service():
    """Create new HTTP service with single backend URL"""
    if request.method == 'POST':
        name = request.form.get('name', '').strip()
        url = request.form.get('url', '').strip()

        if not name:
            flash('Service name is required.', 'danger')
            return render_template('http/create_service.html', form_data=request.form)

        if not url:
            flash('Backend URL is required.', 'danger')
            return render_template('http/create_service.html', form_data=request.form)

        try:
            success = config_manager.create_simple_service(name, url)
            if success:
                flash(f'Service "{name}" created successfully!', 'success')
                return redirect(url_for('list_services'))

            flash(f'Failed to create service "{name}".', 'danger')
            return render_template('http/create_service.html', form_data=request.form)
        except Exception as e:
            flash(f'Error creating service: {str(e)}', 'danger')
            return render_template('http/create_service.html', form_data=request.form)

    return render_template('http/create_service.html', form_data={})


@app.route('/services/delete/<name>', methods=['POST'])
def delete_service(name):
    """Delete service if not referenced by routers"""
    try:
        routers = config_manager.list_routers()
        dependent_routers = [router.name for router in routers if router.service == name]

        if dependent_routers:
            flash(
                f'Cannot delete service "{name}". It is used by router(s): {", ".join(dependent_routers)}',
                'warning'
            )
            return redirect(url_for('list_services'))

        success = config_manager.delete_service(name)
        if success:
            flash(f'Service "{name}" deleted successfully!', 'success')
        else:
            flash(f'Failed to delete service "{name}".', 'danger')
    except Exception as e:
        flash(f'Error deleting service: {str(e)}', 'danger')

    return redirect(url_for('list_services'))


@app.route('/middlewares')
def list_middlewares():
    """List all middlewares"""
    try:
        middlewares = config_manager.list_middlewares()
        middleware_types = {}
        for middleware_name in middlewares:
            middleware_info = etcd_client.get_http_middleware(middleware_name)
            if middleware_info:
                middleware_types[middleware_name] = middleware_info[0].value
            else:
                middleware_types[middleware_name] = 'unknown'

        return render_template(
            'http/middlewares.html',
            middlewares=middlewares,
            middleware_types=middleware_types
        )
    except Exception as e:
        flash(f'Error loading middlewares: {str(e)}', 'danger')
        return render_template('http/middlewares.html', middlewares=[], middleware_types={})


@app.route('/middlewares/create', methods=['GET', 'POST'])
def create_middleware():
    """Create practical baseline middleware types."""
    if request.method == 'POST':
        name = request.form.get('name', '').strip()
        middleware_type = request.form.get('middleware_type', '').strip()

        if not name:
            flash('Middleware name is required.', 'danger')
            return render_template('http/create_middleware.html', form_data=request.form)

        if not middleware_type:
            flash('Middleware type is required.', 'danger')
            return render_template('http/create_middleware.html', form_data=request.form)

        try:
            if config_manager.middleware_exists(name):
                flash(f'Middleware "{name}" already exists.', 'danger')
                return render_template('http/create_middleware.html', form_data=request.form)

            middleware_enum = None
            middleware_config = None

            if middleware_type == MiddlewareType.ADD_PREFIX.value:
                prefix = request.form.get('prefix', '').strip()
                if not prefix:
                    flash('Prefix is required for addPrefix middleware.', 'danger')
                    return render_template('http/create_middleware.html', form_data=request.form)

                middleware_enum = MiddlewareType.ADD_PREFIX
                middleware_config = AddPrefixMiddleware(
                    name=name,
                    type=MiddlewareType.ADD_PREFIX,
                    prefix=prefix,
                )

            elif middleware_type == MiddlewareType.STRIP_PREFIX.value:
                prefixes = _parse_csv(request.form.get('prefixes', '').strip())
                if not prefixes:
                    flash('At least one prefix is required for stripPrefix middleware.', 'danger')
                    return render_template('http/create_middleware.html', form_data=request.form)

                middleware_enum = MiddlewareType.STRIP_PREFIX
                middleware_config = StripPrefixMiddleware(
                    name=name,
                    type=MiddlewareType.STRIP_PREFIX,
                    prefixes=prefixes,
                )

            elif middleware_type == MiddlewareType.REDIRECT_SCHEME.value:
                scheme = request.form.get('scheme', '').strip()
                permanent = request.form.get('permanent') == 'on'
                if not scheme:
                    flash('Scheme is required for redirectScheme middleware.', 'danger')
                    return render_template('http/create_middleware.html', form_data=request.form)

                middleware_enum = MiddlewareType.REDIRECT_SCHEME
                middleware_config = RedirectSchemeMiddleware(
                    name=name,
                    type=MiddlewareType.REDIRECT_SCHEME,
                    scheme=scheme,
                    permanent=permanent,
                )

            elif middleware_type == MiddlewareType.RATE_LIMIT.value:
                average_raw = request.form.get('average', '').strip()
                burst_raw = request.form.get('burst', '').strip()
                period = request.form.get('period', '').strip()

                average = _parse_int(average_raw, default=-1)
                burst = _parse_int(burst_raw, default=-1)

                if average < 0:
                    flash('Average must be a valid non-negative integer for rateLimit middleware.', 'danger')
                    return render_template('http/create_middleware.html', form_data=request.form)

                if burst < 0:
                    flash('Burst must be a valid non-negative integer for rateLimit middleware.', 'danger')
                    return render_template('http/create_middleware.html', form_data=request.form)

                if not period:
                    flash('Period is required for rateLimit middleware.', 'danger')
                    return render_template('http/create_middleware.html', form_data=request.form)

                middleware_enum = MiddlewareType.RATE_LIMIT
                middleware_config = RateLimitMiddleware(
                    name=name,
                    type=MiddlewareType.RATE_LIMIT,
                    average=average,
                    burst=burst,
                    period=period,
                    use_ip_strategy='use_ip_strategy' in request.form,
                    ip_depth=_parse_int(request.form.get('rl_ip_depth', '0'), default=0),
                    excluded_ips=_parse_csv(request.form.get('rl_excluded_ips', '').strip()),
                    use_request_host='use_request_host' in request.form,
                    use_request_header=request.form.get('use_request_header', '').strip(),
                )

            elif middleware_type == MiddlewareType.BASIC_AUTH.value:
                users = _parse_csv(request.form.get('users', '').strip())
                realm = request.form.get('realm', '').strip()
                remove_header = request.form.get('remove_header') == 'on'

                if not users:
                    flash('At least one user entry is required for basicAuth middleware.', 'danger')
                    return render_template('http/create_middleware.html', form_data=request.form)

                for user_entry in users:
                    if ':' not in user_entry:
                        flash('Each basicAuth user must be in user:hashedpass format.', 'danger')
                        return render_template('http/create_middleware.html', form_data=request.form)

                middleware_enum = MiddlewareType.BASIC_AUTH
                middleware_config = BasicAuthMiddleware(
                    name=name, type=MiddlewareType.BASIC_AUTH,
                    users=users, realm=realm, remove_header=remove_header,
                )

            elif middleware_type == MiddlewareType.DIGEST_AUTH.value:
                users = _parse_csv(request.form.get('dauth_users', '').strip())
                realm = request.form.get('dauth_realm', 'Restricted').strip()
                remove_header = request.form.get('dauth_remove_header') == 'on'
                if not users:
                    flash('At least one user entry is required for digestAuth middleware.', 'danger')
                    return render_template('http/create_middleware.html', form_data=request.form)
                middleware_enum = MiddlewareType.DIGEST_AUTH
                middleware_config = DigestAuthMiddleware(
                    name=name, type=MiddlewareType.DIGEST_AUTH,
                    users=users, realm=realm, remove_header=remove_header,
                )

            elif middleware_type == MiddlewareType.FORWARD_AUTH.value:
                address = request.form.get('fa_address', '').strip()
                if not address:
                    flash('Address is required for forwardAuth middleware.', 'danger')
                    return render_template('http/create_middleware.html', form_data=request.form)
                middleware_enum = MiddlewareType.FORWARD_AUTH
                middleware_config = ForwardAuthMiddleware(
                    name=name, type=MiddlewareType.FORWARD_AUTH,
                    address=address,
                    trust_forward_header=request.form.get('fa_trust_forward') == 'on',
                    auth_response_headers=_parse_csv(request.form.get('fa_response_headers', '')),
                    tls_insecure_skip_verify=request.form.get('fa_tls_insecure') == 'on',
                )

            elif middleware_type == MiddlewareType.IP_WHITELIST.value:
                source_range = _parse_csv(request.form.get('ip_source_range', '').strip())
                if not source_range:
                    flash('At least one CIDR range is required for ipWhiteList middleware.', 'danger')
                    return render_template('http/create_middleware.html', form_data=request.form)
                middleware_enum = MiddlewareType.IP_WHITELIST
                middleware_config = IPWhiteListMiddleware(
                    name=name, type=MiddlewareType.IP_WHITELIST,
                    source_range=source_range,
                    ip_depth=_parse_int(request.form.get('ip_depth', '0'), default=0),
                )

            elif middleware_type == MiddlewareType.HEADERS.value:
                middleware_enum = MiddlewareType.HEADERS
                middleware_config = HeadersMiddleware(
                    name=name, type=MiddlewareType.HEADERS,
                    ssl_redirect=request.form.get('h_ssl_redirect') == 'on',
                    sts_seconds=_parse_int(request.form.get('h_sts_seconds', '0'), default=0),
                    sts_include_subdomains=request.form.get('h_sts_subdomains') == 'on',
                    sts_preload=request.form.get('h_sts_preload') == 'on',
                    force_sts_header=request.form.get('h_force_sts') == 'on',
                    frame_deny=request.form.get('h_frame_deny') == 'on',
                    content_type_nosniff=request.form.get('h_nosniff') == 'on',
                    browser_xss_filter=request.form.get('h_xss_filter') == 'on',
                    content_security_policy=request.form.get('h_csp', '').strip(),
                    referrer_policy=request.form.get('h_referrer_policy', '').strip(),
                    access_control_allow_credentials=request.form.get('h_cors_credentials') == 'on',
                    access_control_allow_origin_list=_parse_csv(request.form.get('h_cors_origins', '')),
                    access_control_allow_methods=_parse_csv(request.form.get('h_cors_methods', '')),
                    access_control_allow_headers=_parse_csv(request.form.get('h_cors_headers', '')),
                    access_control_max_age=_parse_int(request.form.get('h_cors_max_age', '0'), default=0),
                )

            elif middleware_type == MiddlewareType.COMPRESS.value:
                middleware_enum = MiddlewareType.COMPRESS
                middleware_config = CompressMiddleware(
                    name=name, type=MiddlewareType.COMPRESS,
                    excluded_content_types=_parse_csv(request.form.get('cmp_excluded', 'text/event-stream')),
                    min_response_body_bytes=_parse_int(request.form.get('cmp_min_bytes', '1024'), default=1024),
                )

            elif middleware_type == MiddlewareType.RETRY.value:
                attempts = _parse_int(request.form.get('retry_attempts', '4'), default=4)
                middleware_enum = MiddlewareType.RETRY
                middleware_config = RetryMiddleware(
                    name=name, type=MiddlewareType.RETRY,
                    attempts=attempts,
                    initial_interval=request.form.get('retry_interval', '100ms').strip() or '100ms',
                )

            elif middleware_type == MiddlewareType.CIRCUIT_BREAKER.value:
                expression = request.form.get('cb_expression', '').strip()
                if not expression:
                    flash('Expression is required for circuitBreaker middleware.', 'danger')
                    return render_template('http/create_middleware.html', form_data=request.form)
                middleware_enum = MiddlewareType.CIRCUIT_BREAKER
                middleware_config = CircuitBreakerMiddleware(
                    name=name, type=MiddlewareType.CIRCUIT_BREAKER,
                    expression=expression,
                    check_period=request.form.get('cb_check_period', '10s').strip() or '10s',
                    fallback_duration=request.form.get('cb_fallback', '30s').strip() or '30s',
                    recovery_duration=request.form.get('cb_recovery', '10s').strip() or '10s',
                )

            elif middleware_type == MiddlewareType.BUFFERING.value:
                middleware_enum = MiddlewareType.BUFFERING
                middleware_config = BufferingMiddleware(
                    name=name, type=MiddlewareType.BUFFERING,
                    max_request_body_bytes=_parse_int(request.form.get('buf_max_req', '2097152'), default=2097152),
                    max_response_body_bytes=_parse_int(request.form.get('buf_max_resp', '2097152'), default=2097152),
                    retry_expression=request.form.get('buf_retry_expr', '').strip(),
                )

            elif middleware_type == MiddlewareType.IN_FLIGHT_REQ.value:
                amount = _parse_int(request.form.get('ifr_amount', '10'), default=10)
                middleware_enum = MiddlewareType.IN_FLIGHT_REQ
                middleware_config = InFlightReqMiddleware(
                    name=name, type=MiddlewareType.IN_FLIGHT_REQ, amount=amount,
                )

            elif middleware_type == MiddlewareType.REDIRECT_REGEX.value:
                regex = request.form.get('rr_regex', '').strip()
                replacement = request.form.get('rr_replacement', '').strip()
                if not regex:
                    flash('Regex is required for redirectRegex middleware.', 'danger')
                    return render_template('http/create_middleware.html', form_data=request.form)
                middleware_enum = MiddlewareType.REDIRECT_REGEX
                middleware_config = RedirectRegexMiddleware(
                    name=name, type=MiddlewareType.REDIRECT_REGEX,
                    regex=regex, replacement=replacement,
                    permanent=request.form.get('rr_permanent') == 'on',
                )

            elif middleware_type == MiddlewareType.STRIP_PREFIX_REGEX.value:
                regex_list = _parse_csv(request.form.get('spr_regex', '').strip())
                if not regex_list:
                    flash('At least one regex is required for stripPrefixRegex middleware.', 'danger')
                    return render_template('http/create_middleware.html', form_data=request.form)
                middleware_enum = MiddlewareType.STRIP_PREFIX_REGEX
                middleware_config = StripPrefixRegexMiddleware(
                    name=name, type=MiddlewareType.STRIP_PREFIX_REGEX, regex=regex_list,
                )

            elif middleware_type == MiddlewareType.REPLACE_PATH.value:
                path = request.form.get('rp_path', '').strip()
                if not path:
                    flash('Path is required for replacePath middleware.', 'danger')
                    return render_template('http/create_middleware.html', form_data=request.form)
                middleware_enum = MiddlewareType.REPLACE_PATH
                middleware_config = ReplacePathMiddleware(
                    name=name, type=MiddlewareType.REPLACE_PATH, path=path,
                )

            elif middleware_type == MiddlewareType.REPLACE_PATH_REGEX.value:
                regex = request.form.get('rpr_regex', '').strip()
                replacement = request.form.get('rpr_replacement', '').strip()
                if not regex:
                    flash('Regex is required for replacePathRegex middleware.', 'danger')
                    return render_template('http/create_middleware.html', form_data=request.form)
                middleware_enum = MiddlewareType.REPLACE_PATH_REGEX
                middleware_config = ReplacePathRegexMiddleware(
                    name=name, type=MiddlewareType.REPLACE_PATH_REGEX,
                    regex=regex, replacement=replacement,
                )

            elif middleware_type == MiddlewareType.CHAIN.value:
                chain_mws = _parse_csv(request.form.get('chain_middlewares', '').strip())
                if not chain_mws:
                    flash('At least one middleware is required for chain middleware.', 'danger')
                    return render_template('http/create_middleware.html', form_data=request.form)
                middleware_enum = MiddlewareType.CHAIN
                middleware_config = ChainMiddleware(
                    name=name, type=MiddlewareType.CHAIN, middlewares=chain_mws,
                )

            elif middleware_type == MiddlewareType.CONTENT_TYPE.value:
                middleware_enum = MiddlewareType.CONTENT_TYPE
                middleware_config = ContentTypeMiddleware(
                    name=name, type=MiddlewareType.CONTENT_TYPE,
                    auto_detect=request.form.get('ct_auto_detect') == 'on',
                )

            elif middleware_type == MiddlewareType.GRPC_WEB.value:
                origins = _parse_csv(request.form.get('grpc_origins', '*'))
                middleware_enum = MiddlewareType.GRPC_WEB
                middleware_config = GrpcWebMiddleware(
                    name=name, type=MiddlewareType.GRPC_WEB, allow_origins=origins,
                )

            elif middleware_type == MiddlewareType.PASS_TLS_CLIENT_CERT.value:
                middleware_enum = MiddlewareType.PASS_TLS_CLIENT_CERT
                middleware_config = PassTLSClientCertMiddleware(
                    name=name, type=MiddlewareType.PASS_TLS_CLIENT_CERT,
                    pem=request.form.get('ptcc_pem') == 'on',
                )

            else:
                flash(f'Middleware type "{middleware_type}" is not supported.', 'danger')
                return render_template('http/create_middleware.html', form_data=request.form)

            success = config_manager.create_middleware(name, middleware_enum, middleware_config)
            if success:
                flash(f'Middleware "{name}" created successfully!', 'success')
                return redirect(url_for('list_middlewares'))

            flash(f'Failed to create middleware "{name}".', 'danger')
            return render_template('http/create_middleware.html', form_data=request.form)

        except ValidationError as e:
            flash(f'Validation error: {str(e)}', 'danger')
            return render_template('http/create_middleware.html', form_data=request.form)
        except Exception as e:
            flash(f'Error creating middleware: {str(e)}', 'danger')
            return render_template('http/create_middleware.html', form_data=request.form)

    return render_template('http/create_middleware.html', form_data={})


@app.route('/middlewares/edit/<name>', methods=['GET', 'POST'])
def edit_middleware(name):
    """Edit supported middleware types by recreating them with the same name."""
    existing_middleware = etcd_client.get_http_middleware(name)
    if not existing_middleware:
        flash(f'Middleware "{name}" not found.', 'warning')
        return redirect(url_for('list_middlewares'))

    middleware_type, middleware_config = existing_middleware
    supported_types = {
        MiddlewareType.ADD_PREFIX, MiddlewareType.STRIP_PREFIX,
        MiddlewareType.STRIP_PREFIX_REGEX, MiddlewareType.REPLACE_PATH,
        MiddlewareType.REPLACE_PATH_REGEX, MiddlewareType.REDIRECT_SCHEME,
        MiddlewareType.REDIRECT_REGEX, MiddlewareType.RATE_LIMIT,
        MiddlewareType.CIRCUIT_BREAKER, MiddlewareType.RETRY,
        MiddlewareType.COMPRESS, MiddlewareType.BASIC_AUTH,
        MiddlewareType.DIGEST_AUTH, MiddlewareType.FORWARD_AUTH,
        MiddlewareType.IP_WHITELIST, MiddlewareType.HEADERS,
        MiddlewareType.BUFFERING, MiddlewareType.IN_FLIGHT_REQ,
        MiddlewareType.CHAIN, MiddlewareType.CONTENT_TYPE,
        MiddlewareType.GRPC_WEB, MiddlewareType.PASS_TLS_CLIENT_CERT,
    }

    if middleware_type not in supported_types:
        flash(
            f'Middleware "{name}" type "{middleware_type.value}" is not supported for editing in this UI.',
            'warning'
        )
        return redirect(url_for('list_middlewares'))

    middleware_config = middleware_config or {}

    if request.method == 'POST':
        try:
            if middleware_type == MiddlewareType.ADD_PREFIX:
                prefix = request.form.get('prefix', '').strip()
                if not prefix:
                    flash('Prefix is required for addPrefix middleware.', 'danger')
                    return render_template(
                        'http/edit_middleware.html',
                        middleware_name=name,
                        middleware_type=middleware_type.value,
                        form_data=request.form,
                    )

                config_obj = AddPrefixMiddleware(
                    name=name,
                    type=MiddlewareType.ADD_PREFIX,
                    prefix=prefix,
                )

            elif middleware_type == MiddlewareType.STRIP_PREFIX:
                prefixes = _parse_csv(request.form.get('prefixes', '').strip())
                if not prefixes:
                    flash('At least one prefix is required for stripPrefix middleware.', 'danger')
                    return render_template(
                        'http/edit_middleware.html',
                        middleware_name=name,
                        middleware_type=middleware_type.value,
                        form_data=request.form,
                    )

                config_obj = StripPrefixMiddleware(
                    name=name,
                    type=MiddlewareType.STRIP_PREFIX,
                    prefixes=prefixes,
                )

            elif middleware_type == MiddlewareType.REDIRECT_SCHEME:
                scheme = request.form.get('scheme', '').strip()
                permanent = request.form.get('permanent') == 'on'
                if not scheme:
                    flash('Scheme is required for redirectScheme middleware.', 'danger')
                    return render_template(
                        'http/edit_middleware.html',
                        middleware_name=name,
                        middleware_type=middleware_type.value,
                        form_data=request.form,
                    )

                config_obj = RedirectSchemeMiddleware(
                    name=name,
                    type=MiddlewareType.REDIRECT_SCHEME,
                    scheme=scheme,
                    permanent=permanent,
                )

            elif middleware_type == MiddlewareType.RATE_LIMIT:
                average_raw = request.form.get('average', '').strip()
                burst_raw = request.form.get('burst', '').strip()
                period = request.form.get('period', '').strip()
                average = _parse_int(average_raw, default=-1)
                burst = _parse_int(burst_raw, default=-1)

                if average < 0:
                    flash('Average must be a valid non-negative integer for rateLimit middleware.', 'danger')
                    return render_template(
                        'http/edit_middleware.html',
                        middleware_name=name,
                        middleware_type=middleware_type.value,
                        form_data=request.form,
                    )

                if burst < 0:
                    flash('Burst must be a valid non-negative integer for rateLimit middleware.', 'danger')
                    return render_template(
                        'http/edit_middleware.html',
                        middleware_name=name,
                        middleware_type=middleware_type.value,
                        form_data=request.form,
                    )

                if not period:
                    flash('Period is required for rateLimit middleware.', 'danger')
                    return render_template(
                        'http/edit_middleware.html',
                        middleware_name=name,
                        middleware_type=middleware_type.value,
                        form_data=request.form,
                    )

                config_obj = RateLimitMiddleware(
                    name=name,
                    type=MiddlewareType.RATE_LIMIT,
                    average=average,
                    burst=burst,
                    period=period,
                    use_ip_strategy='use_ip_strategy' in request.form,
                    ip_depth=_parse_int(request.form.get('rl_ip_depth', '0'), default=0),
                    excluded_ips=_parse_csv(request.form.get('rl_excluded_ips', '').strip()),
                    use_request_host='use_request_host' in request.form,
                    use_request_header=request.form.get('use_request_header', '').strip(),
                )

            elif middleware_type == MiddlewareType.BASIC_AUTH:
                users = _parse_csv(request.form.get('users', '').strip())
                realm = request.form.get('realm', '').strip()
                remove_header = request.form.get('remove_header') == 'on'
                if not users:
                    flash('At least one user entry is required for basicAuth middleware.', 'danger')
                    return render_template('http/edit_middleware.html', middleware_name=name, middleware_type=middleware_type.value, form_data=request.form)
                for user_entry in users:
                    if ':' not in user_entry:
                        flash('Each basicAuth user must be in user:hashedpass format.', 'danger')
                        return render_template('http/edit_middleware.html', middleware_name=name, middleware_type=middleware_type.value, form_data=request.form)
                config_obj = BasicAuthMiddleware(name=name, type=MiddlewareType.BASIC_AUTH, users=users, realm=realm, remove_header=remove_header)

            elif middleware_type == MiddlewareType.DIGEST_AUTH:
                users = _parse_csv(request.form.get('dauth_users', '').strip())
                if not users:
                    flash('At least one user entry is required for digestAuth.', 'danger')
                    return render_template('http/edit_middleware.html', middleware_name=name, middleware_type=middleware_type.value, form_data=request.form)
                config_obj = DigestAuthMiddleware(name=name, type=MiddlewareType.DIGEST_AUTH, users=users,
                    realm=request.form.get('dauth_realm', 'Restricted').strip(),
                    remove_header=request.form.get('dauth_remove_header') == 'on')

            elif middleware_type == MiddlewareType.FORWARD_AUTH:
                address = request.form.get('fa_address', '').strip()
                if not address:
                    flash('Address is required for forwardAuth.', 'danger')
                    return render_template('http/edit_middleware.html', middleware_name=name, middleware_type=middleware_type.value, form_data=request.form)
                config_obj = ForwardAuthMiddleware(name=name, type=MiddlewareType.FORWARD_AUTH, address=address,
                    trust_forward_header=request.form.get('fa_trust_forward') == 'on',
                    auth_response_headers=_parse_csv(request.form.get('fa_response_headers', '')),
                    tls_insecure_skip_verify=request.form.get('fa_tls_insecure') == 'on')

            elif middleware_type == MiddlewareType.IP_WHITELIST:
                source_range = _parse_csv(request.form.get('ip_source_range', '').strip())
                if not source_range:
                    flash('At least one CIDR range is required for ipWhiteList.', 'danger')
                    return render_template('http/edit_middleware.html', middleware_name=name, middleware_type=middleware_type.value, form_data=request.form)
                config_obj = IPWhiteListMiddleware(name=name, type=MiddlewareType.IP_WHITELIST, source_range=source_range,
                    ip_depth=_parse_int(request.form.get('ip_depth', '0'), default=0))

            elif middleware_type == MiddlewareType.HEADERS:
                config_obj = HeadersMiddleware(name=name, type=MiddlewareType.HEADERS,
                    ssl_redirect=request.form.get('h_ssl_redirect') == 'on',
                    sts_seconds=_parse_int(request.form.get('h_sts_seconds', '0'), default=0),
                    sts_include_subdomains=request.form.get('h_sts_subdomains') == 'on',
                    sts_preload=request.form.get('h_sts_preload') == 'on',
                    force_sts_header=request.form.get('h_force_sts') == 'on',
                    frame_deny=request.form.get('h_frame_deny') == 'on',
                    content_type_nosniff=request.form.get('h_nosniff') == 'on',
                    browser_xss_filter=request.form.get('h_xss_filter') == 'on',
                    content_security_policy=request.form.get('h_csp', '').strip(),
                    referrer_policy=request.form.get('h_referrer_policy', '').strip(),
                    access_control_allow_credentials=request.form.get('h_cors_credentials') == 'on',
                    access_control_allow_origin_list=_parse_csv(request.form.get('h_cors_origins', '')),
                    access_control_allow_methods=_parse_csv(request.form.get('h_cors_methods', '')),
                    access_control_allow_headers=_parse_csv(request.form.get('h_cors_headers', '')),
                    access_control_max_age=_parse_int(request.form.get('h_cors_max_age', '0'), default=0))

            elif middleware_type == MiddlewareType.COMPRESS:
                config_obj = CompressMiddleware(name=name, type=MiddlewareType.COMPRESS,
                    excluded_content_types=_parse_csv(request.form.get('cmp_excluded', 'text/event-stream')),
                    min_response_body_bytes=_parse_int(request.form.get('cmp_min_bytes', '1024'), default=1024))

            elif middleware_type == MiddlewareType.RETRY:
                config_obj = RetryMiddleware(name=name, type=MiddlewareType.RETRY,
                    attempts=_parse_int(request.form.get('retry_attempts', '4'), default=4),
                    initial_interval=request.form.get('retry_interval', '100ms').strip() or '100ms')

            elif middleware_type == MiddlewareType.CIRCUIT_BREAKER:
                expression = request.form.get('cb_expression', '').strip()
                if not expression:
                    flash('Expression is required for circuitBreaker.', 'danger')
                    return render_template('http/edit_middleware.html', middleware_name=name, middleware_type=middleware_type.value, form_data=request.form)
                config_obj = CircuitBreakerMiddleware(name=name, type=MiddlewareType.CIRCUIT_BREAKER,
                    expression=expression,
                    check_period=request.form.get('cb_check_period', '10s').strip() or '10s',
                    fallback_duration=request.form.get('cb_fallback', '30s').strip() or '30s',
                    recovery_duration=request.form.get('cb_recovery', '10s').strip() or '10s')

            elif middleware_type == MiddlewareType.BUFFERING:
                config_obj = BufferingMiddleware(name=name, type=MiddlewareType.BUFFERING,
                    max_request_body_bytes=_parse_int(request.form.get('buf_max_req', '2097152'), default=2097152),
                    max_response_body_bytes=_parse_int(request.form.get('buf_max_resp', '2097152'), default=2097152),
                    retry_expression=request.form.get('buf_retry_expr', '').strip())

            elif middleware_type == MiddlewareType.IN_FLIGHT_REQ:
                config_obj = InFlightReqMiddleware(name=name, type=MiddlewareType.IN_FLIGHT_REQ,
                    amount=_parse_int(request.form.get('ifr_amount', '10'), default=10))

            elif middleware_type == MiddlewareType.REDIRECT_REGEX:
                regex = request.form.get('rr_regex', '').strip()
                if not regex:
                    flash('Regex is required for redirectRegex.', 'danger')
                    return render_template('http/edit_middleware.html', middleware_name=name, middleware_type=middleware_type.value, form_data=request.form)
                config_obj = RedirectRegexMiddleware(name=name, type=MiddlewareType.REDIRECT_REGEX,
                    regex=regex, replacement=request.form.get('rr_replacement', '').strip(),
                    permanent=request.form.get('rr_permanent') == 'on')

            elif middleware_type == MiddlewareType.STRIP_PREFIX_REGEX:
                regex_list = _parse_csv(request.form.get('spr_regex', '').strip())
                if not regex_list:
                    flash('At least one regex is required for stripPrefixRegex.', 'danger')
                    return render_template('http/edit_middleware.html', middleware_name=name, middleware_type=middleware_type.value, form_data=request.form)
                config_obj = StripPrefixRegexMiddleware(name=name, type=MiddlewareType.STRIP_PREFIX_REGEX, regex=regex_list)

            elif middleware_type == MiddlewareType.REPLACE_PATH:
                path = request.form.get('rp_path', '').strip()
                if not path:
                    flash('Path is required for replacePath.', 'danger')
                    return render_template('http/edit_middleware.html', middleware_name=name, middleware_type=middleware_type.value, form_data=request.form)
                config_obj = ReplacePathMiddleware(name=name, type=MiddlewareType.REPLACE_PATH, path=path)

            elif middleware_type == MiddlewareType.REPLACE_PATH_REGEX:
                regex = request.form.get('rpr_regex', '').strip()
                if not regex:
                    flash('Regex is required for replacePathRegex.', 'danger')
                    return render_template('http/edit_middleware.html', middleware_name=name, middleware_type=middleware_type.value, form_data=request.form)
                config_obj = ReplacePathRegexMiddleware(name=name, type=MiddlewareType.REPLACE_PATH_REGEX,
                    regex=regex, replacement=request.form.get('rpr_replacement', '').strip())

            elif middleware_type == MiddlewareType.CHAIN:
                chain_mws = _parse_csv(request.form.get('chain_middlewares', '').strip())
                if not chain_mws:
                    flash('At least one middleware is required for chain.', 'danger')
                    return render_template('http/edit_middleware.html', middleware_name=name, middleware_type=middleware_type.value, form_data=request.form)
                config_obj = ChainMiddleware(name=name, type=MiddlewareType.CHAIN, middlewares=chain_mws)

            elif middleware_type == MiddlewareType.CONTENT_TYPE:
                config_obj = ContentTypeMiddleware(name=name, type=MiddlewareType.CONTENT_TYPE,
                    auto_detect=request.form.get('ct_auto_detect') == 'on')

            elif middleware_type == MiddlewareType.GRPC_WEB:
                config_obj = GrpcWebMiddleware(name=name, type=MiddlewareType.GRPC_WEB,
                    allow_origins=_parse_csv(request.form.get('grpc_origins', '*')))

            elif middleware_type == MiddlewareType.PASS_TLS_CLIENT_CERT:
                config_obj = PassTLSClientCertMiddleware(name=name, type=MiddlewareType.PASS_TLS_CLIENT_CERT,
                    pem=request.form.get('ptcc_pem') == 'on')

            else:
                flash(f'Middleware type "{middleware_type.value}" is not supported for editing.', 'warning')
                return redirect(url_for('list_middlewares'))

            success = config_manager.create_middleware(name, middleware_type, config_obj)
            if success:
                flash(f'Middleware "{name}" updated successfully!', 'success')
                return redirect(url_for('list_middlewares'))

            flash(f'Failed to update middleware "{name}".', 'danger')
            return render_template(
                'http/edit_middleware.html',
                middleware_name=name,
                middleware_type=middleware_type.value,
                form_data=request.form,
            )

        except ValidationError as e:
            flash(f'Validation error: {str(e)}', 'danger')
            return render_template(
                'http/edit_middleware.html',
                middleware_name=name,
                middleware_type=middleware_type.value,
                form_data=request.form,
            )
        except Exception as e:
            flash(f'Error updating middleware: {str(e)}', 'danger')
            return render_template(
                'http/edit_middleware.html',
                middleware_name=name,
                middleware_type=middleware_type.value,
                form_data=request.form,
            )

    form_data = {
        'middleware_type': middleware_type.value,
        # addPrefix / stripPrefix / stripPrefixRegex
        'prefix': middleware_config.get('prefix', ''),
        'prefixes': ', '.join(middleware_config.get('prefixes', []) or []),
        'spr_regex': ', '.join(middleware_config.get('regex', []) if isinstance(middleware_config.get('regex'), list) else []),
        # replacePath / replacePathRegex
        'rp_path': middleware_config.get('path', ''),
        'rpr_regex': middleware_config.get('regex', '') if not isinstance(middleware_config.get('regex'), list) else '',
        'rpr_replacement': middleware_config.get('replacement', ''),
        # redirectScheme
        'scheme': middleware_config.get('scheme', 'https'),
        'permanent': middleware_config.get('permanent', True),
        # redirectRegex
        'rr_regex': middleware_config.get('regex', '') if not isinstance(middleware_config.get('regex'), list) else '',
        'rr_replacement': middleware_config.get('replacement', ''),
        'rr_permanent': middleware_config.get('permanent', False),
        # rateLimit
        'average': middleware_config.get('average', 100),
        'burst': middleware_config.get('burst', 50),
        'period': middleware_config.get('period', '1s'),
        'use_ip_strategy': middleware_config.get('use_ip_strategy', True),
        'rl_ip_depth': middleware_config.get('ip_depth', 0),
        'rl_excluded_ips': ', '.join(middleware_config.get('excluded_ips', []) or []),
        'use_request_host': middleware_config.get('use_request_host', False),
        'use_request_header': middleware_config.get('use_request_header', ''),
        # retry
        'retry_attempts': middleware_config.get('attempts', 4),
        'retry_interval': middleware_config.get('initial_interval', '100ms'),
        # circuitBreaker
        'cb_expression': middleware_config.get('expression', 'NetworkErrorRatio() > 0.30'),
        'cb_check_period': middleware_config.get('check_period', '10s'),
        'cb_fallback': middleware_config.get('fallback_duration', '30s'),
        'cb_recovery': middleware_config.get('recovery_duration', '10s'),
        # compress
        'cmp_excluded': ', '.join(middleware_config.get('excluded_content_types', ['text/event-stream']) or []),
        'cmp_min_bytes': middleware_config.get('min_response_body_bytes', 1024),
        # basicAuth / digestAuth
        'users': ', '.join(middleware_config.get('users', []) or []),
        'realm': middleware_config.get('realm', 'Restricted'),
        'remove_header': middleware_config.get('remove_header', False),
        'dauth_users': ', '.join(middleware_config.get('users', []) or []),
        'dauth_realm': middleware_config.get('realm', 'Restricted'),
        'dauth_remove_header': middleware_config.get('remove_header', False),
        # forwardAuth
        'fa_address': middleware_config.get('address', ''),
        'fa_trust_forward': middleware_config.get('trust_forward_header', False),
        'fa_response_headers': ', '.join(middleware_config.get('auth_response_headers', []) or []),
        'fa_tls_insecure': middleware_config.get('tls_insecure_skip_verify', False),
        # ipWhiteList
        'ip_source_range': ', '.join(middleware_config.get('source_range', []) or []),
        'ip_depth': middleware_config.get('ip_depth', 0),
        # headers security / CORS
        'h_ssl_redirect': middleware_config.get('ssl_redirect', False),
        'h_sts_seconds': middleware_config.get('sts_seconds', 0),
        'h_sts_subdomains': middleware_config.get('sts_include_subdomains', False),
        'h_sts_preload': middleware_config.get('sts_preload', False),
        'h_force_sts': middleware_config.get('force_sts_header', False),
        'h_frame_deny': middleware_config.get('frame_deny', False),
        'h_nosniff': middleware_config.get('content_type_nosniff', False),
        'h_xss_filter': middleware_config.get('browser_xss_filter', False),
        'h_csp': middleware_config.get('content_security_policy', ''),
        'h_referrer_policy': middleware_config.get('referrer_policy', ''),
        'h_cors_credentials': middleware_config.get('access_control_allow_credentials', False),
        'h_cors_origins': ', '.join(middleware_config.get('access_control_allow_origin_list', []) or []),
        'h_cors_methods': ', '.join(middleware_config.get('access_control_allow_methods', []) or []),
        'h_cors_headers': ', '.join(middleware_config.get('access_control_allow_headers', []) or []),
        'h_cors_max_age': middleware_config.get('access_control_max_age', 0),
        # buffering
        'buf_max_req': middleware_config.get('max_request_body_bytes', 2097152),
        'buf_max_resp': middleware_config.get('max_response_body_bytes', 2097152),
        'buf_retry_expr': middleware_config.get('retry_expression', ''),
        # inFlightReq
        'ifr_amount': middleware_config.get('amount', 10),
        # chain
        'chain_middlewares': ', '.join(middleware_config.get('middlewares', []) or []),
        # contentType
        'ct_auto_detect': middleware_config.get('auto_detect', True),
        # grpcWeb
        'grpc_origins': ', '.join(middleware_config.get('allow_origins', ['*']) or ['*']),
        # passTLSClientCert
        'ptcc_pem': middleware_config.get('pem', False),
    }
    return render_template(
        'http/edit_middleware.html',
        middleware_name=name,
        middleware_type=middleware_type.value,
        form_data=form_data,
    )


@app.route('/middlewares/<name>')
def middleware_detail(name):
    """Show middleware type and parsed config."""
    try:
        middleware_info = etcd_client.get_http_middleware(name)
        if not middleware_info:
            flash(f'Middleware "{name}" not found.', 'warning')
            return render_template(
                'http/middleware_detail.html',
                middleware_name=name,
                middleware_type='unknown',
                middleware_config={},
            )

        middleware_type, middleware_config = middleware_info
        return render_template(
            'http/middleware_detail.html',
            middleware_name=name,
            middleware_type=middleware_type.value,
            middleware_config=middleware_config or {},
        )
    except Exception as e:
        flash(f'Error loading middleware detail: {str(e)}', 'danger')
        return render_template(
            'http/middleware_detail.html',
            middleware_name=name,
            middleware_type='unknown',
            middleware_config={},
        )


@app.route('/middlewares/delete/<name>', methods=['POST'])
def delete_middleware(name):
    """Delete middleware if not referenced by routers."""
    try:
        routers = config_manager.list_routers()
        dependent_routers = [router.name for router in routers if name in router.middlewares]

        if dependent_routers:
            flash(
                f'Cannot delete middleware "{name}". It is used by router(s): {", ".join(dependent_routers)}',
                'warning'
            )
            return redirect(url_for('list_middlewares'))

        success = config_manager.delete_middleware(name)
        if success:
            flash(f'Middleware "{name}" deleted successfully!', 'success')
        else:
            flash(f'Failed to delete middleware "{name}".', 'danger')
    except ValidationError as e:
        flash(f'Cannot delete middleware "{name}": {str(e)}', 'warning')
    except Exception as e:
        flash(f'Error deleting middleware: {str(e)}', 'danger')

    return redirect(url_for('list_middlewares'))


@app.route('/domains')
def list_domains():
    """List all configured domains."""
    try:
        domains = config_manager.get_domains()
        return render_template('http/domains.html', domains=domains)
    except Exception as e:
        flash(f'Error loading domains: {str(e)}', 'danger')
        return render_template('http/domains.html', domains=[])


@app.route('/domains/create', methods=['GET', 'POST'])
def create_domain():
    """Create a new domain registry entry."""
    if request.method == 'POST':
        name = request.form.get('name', '').strip()
        cert_resolver = request.form.get('cert_resolver', '').strip()
        set_default = request.form.get('set_default') == 'on'
        sans = _parse_csv(request.form.get('sans', '').strip())

        if not name:
            flash('Domain name is required.', 'danger')
            return render_template('http/create_domain.html', form_data=request.form)

        if not cert_resolver:
            flash('Certificate resolver is required.', 'danger')
            return render_template('http/create_domain.html', form_data=request.form)

        try:
            domain = Domain(
                name=name,
                cert_resolver=cert_resolver,
                sans=sans,
            )
            success = config_manager.add_domain(domain, set_as_default=set_default)
            if success:
                flash(f'Domain "{name}" created successfully!', 'success')
                return redirect(url_for('list_domains'))

            flash(f'Failed to create domain "{name}". It may already exist.', 'danger')
            return render_template('http/create_domain.html', form_data=request.form)
        except Exception as e:
            flash(f'Error creating domain: {str(e)}', 'danger')
            return render_template('http/create_domain.html', form_data=request.form)

    return render_template('http/create_domain.html', form_data={})


@app.route('/domains/edit/<name>', methods=['GET', 'POST'])
def edit_domain(name):
    """Edit an existing domain's cert resolver and SANs."""
    domains = config_manager.get_domains()
    domain = next((d for d in domains if d.name == name), None)

    if not domain:
        flash(f'Domain "{name}" not found.', 'warning')
        return redirect(url_for('list_domains'))

    if request.method == 'POST':
        cert_resolver = request.form.get('cert_resolver', '').strip()
        sans = _parse_csv(request.form.get('sans', '').strip())

        if not cert_resolver:
            flash('Certificate resolver is required.', 'danger')
            return render_template('http/edit_domain.html', domain=domain, form_data=request.form)

        try:
            success = config_manager.update_domain(name, cert_resolver=cert_resolver, sans=sans)
            if success:
                flash(f'Domain "{name}" updated successfully!', 'success')
                return redirect(url_for('list_domains'))

            flash(f'Failed to update domain "{name}".', 'danger')
            return render_template('http/edit_domain.html', domain=domain, form_data=request.form)
        except Exception as e:
            flash(f'Error updating domain: {str(e)}', 'danger')
            return render_template('http/edit_domain.html', domain=domain, form_data=request.form)

    form_data = {
        'cert_resolver': domain.cert_resolver,
        'sans': ', '.join(domain.sans or []),
    }
    return render_template('http/edit_domain.html', domain=domain, form_data=form_data)


@app.route('/domains/delete/<name>', methods=['POST'])
def delete_domain(name):
    """Delete domain from global config registry."""
    try:
        success = config_manager.remove_domain(name)
        if success:
            flash(f'Domain "{name}" deleted successfully!', 'success')
        else:
            flash(f'Cannot delete domain "{name}". Ensure at least one domain remains.', 'warning')
    except Exception as e:
        flash(f'Error deleting domain: {str(e)}', 'danger')

    return redirect(url_for('list_domains'))


@app.route('/domains/default/<name>', methods=['POST'])
def set_default_domain(name):
    """Set selected domain as default."""
    try:
        success = config_manager.set_default_domain(name)
        if success:
            flash(f'Domain "{name}" set as default.', 'success')
        else:
            flash(f'Failed to set domain "{name}" as default.', 'danger')
    except Exception as e:
        flash(f'Error setting default domain: {str(e)}', 'danger')

    return redirect(url_for('list_domains'))


@app.route('/api/health')
def health():
    """Health check endpoint"""
    try:
        config_manager.list_routers()
        return jsonify({'status': 'healthy', 'etcd_url': etcd_url})
    except Exception as e:
        return jsonify({'status': 'unhealthy', 'error': str(e)}), 500


# ============================================================
# TCP Router Management
# ============================================================

@app.route('/tcp/routers')
def list_tcp_routers():
    """List all TCP routers."""
    try:
        names = config_manager.list_tcp_routers()
        routers = []
        for name in names:
            r = config_manager.get_tcp_router(name)
            routers.append(r if r else {'name': name})
        return render_template('tcp/tcp_routers.html', routers=routers)
    except Exception as e:
        flash(f'Error loading TCP routers: {str(e)}', 'danger')
        return render_template('tcp/tcp_routers.html', routers=[])


@app.route('/tcp/routers/create', methods=['GET', 'POST'])
def create_tcp_router():
    """Create a new TCP router."""
    try:
        tcp_services = config_manager.list_tcp_services()
        tcp_middlewares = config_manager.list_tcp_middlewares()
        tls_options = config_manager.list_tls_options()
    except Exception:
        tcp_services = []
        tcp_middlewares = []
        tls_options = []

    cert_resolvers = _available_cert_resolvers()
    if request.method == 'POST':
        name = request.form.get('name', '').strip()
        rule = request.form.get('rule', '').strip() or "HostSNI(`*`)"
        service = request.form.get('service', '').strip()
        entrypoints = _normalize_multi(request.form.getlist('entrypoints'))
        middlewares = _normalize_multi(request.form.getlist('middlewares'))
        enable_tls = request.form.get('enable_tls') == 'on'
        tls_passthrough = request.form.get('tls_passthrough') == 'on'
        cert_resolver = request.form.get('cert_resolver', '').strip()
        tls_options_value = request.form.get('tls_options', '').strip()
        priority = _parse_priority(request.form.get('priority', '0'))
        tls_enabled = enable_tls or tls_passthrough

        if not name or not service:
            flash('Name and service are required.', 'danger')
            return render_template(
                'tcp/create_tcp_router.html',
                form_data=request.form,
                tcp_services=tcp_services,
                tcp_middlewares=tcp_middlewares,
                tls_options=tls_options,
                cert_resolvers=cert_resolvers,
                entrypoint_options=TCP_ENTRYPOINT_OPTIONS,
                selected_entrypoints=entrypoints,
                selected_middlewares=middlewares,
            )

        if not tcp_services:
            flash('Create at least one TCP service before creating a TCP router.', 'danger')
            return render_template(
                'tcp/create_tcp_router.html',
                form_data=request.form,
                tcp_services=tcp_services,
                tcp_middlewares=tcp_middlewares,
                tls_options=tls_options,
                cert_resolvers=cert_resolvers,
                entrypoint_options=TCP_ENTRYPOINT_OPTIONS,
                selected_entrypoints=entrypoints,
                selected_middlewares=middlewares,
            )

        if service not in tcp_services:
            flash('Select a valid TCP service from the available options.', 'danger')
            return render_template(
                'tcp/create_tcp_router.html',
                form_data=request.form,
                tcp_services=tcp_services,
                tcp_middlewares=tcp_middlewares,
                tls_options=tls_options,
                cert_resolvers=cert_resolvers,
                entrypoint_options=TCP_ENTRYPOINT_OPTIONS,
                selected_entrypoints=entrypoints,
                selected_middlewares=middlewares,
            )

        if not entrypoints:
            flash('Select at least one TCP entrypoint.', 'danger')
            return render_template(
                'tcp/create_tcp_router.html',
                form_data=request.form,
                tcp_services=tcp_services,
                tcp_middlewares=tcp_middlewares,
                tls_options=tls_options,
                cert_resolvers=cert_resolvers,
                entrypoint_options=TCP_ENTRYPOINT_OPTIONS,
                selected_entrypoints=entrypoints,
                selected_middlewares=middlewares,
            )

        try:
            _validate_allowed_values(
                entrypoints,
                [opt['value'] for opt in TCP_ENTRYPOINT_OPTIONS],
                'TCP entrypoints',
            )
            _validate_allowed_values(middlewares, tcp_middlewares, 'TCP middlewares')
            if tls_enabled and cert_resolver and cert_resolver not in cert_resolvers:
                raise ValidationError('Select a valid TLS certificate resolver.')
            if tls_options_value and tls_options_value not in tls_options:
                raise ValidationError('Select a valid TLS options profile.')
        except ValidationError as e:
            flash(str(e), 'danger')
            return render_template(
                'tcp/create_tcp_router.html',
                form_data=request.form,
                tcp_services=tcp_services,
                tcp_middlewares=tcp_middlewares,
                tls_options=tls_options,
                cert_resolvers=cert_resolvers,
                entrypoint_options=TCP_ENTRYPOINT_OPTIONS,
                selected_entrypoints=entrypoints,
                selected_middlewares=middlewares,
            )

        try:
            tls = None
            if tls_enabled:
                tls = TLSConfig(cert_resolver=cert_resolver, options=tls_options_value)
            router = TCPRouter(
                name=name, rule=rule, service=service,
                entrypoints=entrypoints,
                middlewares=middlewares,
                tls=tls, tls_passthrough=tls_passthrough,
                priority=priority,
            )
            config_manager.create_tcp_router(router)
            flash(f'TCP Router "{name}" created!', 'success')
            return redirect(url_for('list_tcp_routers'))
        except Exception as e:
            flash(f'Error: {str(e)}', 'danger')
            return render_template(
                'tcp/create_tcp_router.html',
                form_data=request.form,
                tcp_services=tcp_services,
                tcp_middlewares=tcp_middlewares,
                tls_options=tls_options,
                cert_resolvers=cert_resolvers,
                entrypoint_options=TCP_ENTRYPOINT_OPTIONS,
                selected_entrypoints=entrypoints,
                selected_middlewares=middlewares,
            )

    return render_template(
        'tcp/create_tcp_router.html',
        form_data={},
        tcp_services=tcp_services,
        tcp_middlewares=tcp_middlewares,
        tls_options=tls_options,
        cert_resolvers=cert_resolvers,
        entrypoint_options=TCP_ENTRYPOINT_OPTIONS,
        selected_entrypoints=['tcp'],
        selected_middlewares=[],
    )


@app.route('/tcp/routers/delete/<name>', methods=['POST'])
@login_required
def delete_tcp_router(name):
    """Delete a TCP router."""
    try:
        config_manager.delete_tcp_router(name)
        flash(f'TCP Router "{name}" deleted.', 'success')
    except Exception as e:
        flash(f'Error: {str(e)}', 'danger')
    return redirect(url_for('list_tcp_routers'))


@app.route('/tcp/routers/edit/<name>', methods=['GET', 'POST'])
def edit_tcp_router(name):
    """Edit an existing TCP router."""
    try:
        tcp_services = config_manager.list_tcp_services()
        tcp_middlewares = config_manager.list_tcp_middlewares()
        tls_options = config_manager.list_tls_options()
    except Exception:
        tcp_services = []
        tcp_middlewares = []
        tls_options = []

    cert_resolvers = _available_cert_resolvers()

    existing = config_manager.get_tcp_router(name)
    if not existing:
        flash(f'TCP Router "{name}" not found.', 'warning')
        return redirect(url_for('list_tcp_routers'))

    if request.method == 'POST':
        rule = request.form.get('rule', '').strip() or "HostSNI(`*`)"
        service = request.form.get('service', '').strip()
        entrypoints = _normalize_multi(request.form.getlist('entrypoints'))
        middlewares = _normalize_multi(request.form.getlist('middlewares'))
        enable_tls = request.form.get('enable_tls') == 'on'
        tls_passthrough = request.form.get('tls_passthrough') == 'on'
        cert_resolver = request.form.get('cert_resolver', '').strip()
        tls_options_value = request.form.get('tls_options', '').strip()
        priority = _parse_priority(request.form.get('priority', '0'))
        tls_enabled = enable_tls or tls_passthrough

        if not service:
            flash('Service is required.', 'danger')
            return render_template(
                'tcp/edit_tcp_router.html',
                router=existing,
                form_data=request.form,
                tcp_services=tcp_services,
                tcp_middlewares=tcp_middlewares,
                tls_options=tls_options,
                cert_resolvers=cert_resolvers,
                entrypoint_options=TCP_ENTRYPOINT_OPTIONS,
                selected_entrypoints=entrypoints,
                selected_middlewares=middlewares,
            )

        if service not in tcp_services:
            flash('Select a valid TCP service from the available options.', 'danger')
            return render_template(
                'tcp/edit_tcp_router.html',
                router=existing,
                form_data=request.form,
                tcp_services=tcp_services,
                tcp_middlewares=tcp_middlewares,
                tls_options=tls_options,
                cert_resolvers=cert_resolvers,
                entrypoint_options=TCP_ENTRYPOINT_OPTIONS,
                selected_entrypoints=entrypoints,
                selected_middlewares=middlewares,
            )

        if not entrypoints:
            flash('Select at least one TCP entrypoint.', 'danger')
            return render_template(
                'tcp/edit_tcp_router.html',
                router=existing,
                form_data=request.form,
                tcp_services=tcp_services,
                tcp_middlewares=tcp_middlewares,
                tls_options=tls_options,
                cert_resolvers=cert_resolvers,
                entrypoint_options=TCP_ENTRYPOINT_OPTIONS,
                selected_entrypoints=entrypoints,
                selected_middlewares=middlewares,
            )

        try:
            _validate_allowed_values(
                entrypoints,
                [opt['value'] for opt in TCP_ENTRYPOINT_OPTIONS],
                'TCP entrypoints',
            )
            _validate_allowed_values(middlewares, tcp_middlewares, 'TCP middlewares')
            if tls_enabled and cert_resolver and cert_resolver not in cert_resolvers:
                raise ValidationError('Select a valid TLS certificate resolver.')
            if tls_options_value and tls_options_value not in tls_options:
                raise ValidationError('Select a valid TLS options profile.')
        except ValidationError as e:
            flash(str(e), 'danger')
            return render_template(
                'tcp/edit_tcp_router.html',
                router=existing,
                form_data=request.form,
                tcp_services=tcp_services,
                tcp_middlewares=tcp_middlewares,
                tls_options=tls_options,
                cert_resolvers=cert_resolvers,
                entrypoint_options=TCP_ENTRYPOINT_OPTIONS,
                selected_entrypoints=entrypoints,
                selected_middlewares=middlewares,
            )

        try:
            tls = None
            if tls_enabled:
                tls = TLSConfig(cert_resolver=cert_resolver, options=tls_options_value)
            router = TCPRouter(
                name=name, rule=rule, service=service,
                entrypoints=entrypoints,
                middlewares=middlewares,
                tls=tls, tls_passthrough=tls_passthrough,
                priority=priority,
            )
            config_manager.update_tcp_router(router)
            flash(f'TCP Router "{name}" updated!', 'success')
            return redirect(url_for('list_tcp_routers'))
        except Exception as e:
            flash(f'Error: {str(e)}', 'danger')
            return render_template(
                'tcp/edit_tcp_router.html',
                router=existing,
                form_data=request.form,
                tcp_services=tcp_services,
                tcp_middlewares=tcp_middlewares,
                tls_options=tls_options,
                cert_resolvers=cert_resolvers,
                entrypoint_options=TCP_ENTRYPOINT_OPTIONS,
                selected_entrypoints=entrypoints,
                selected_middlewares=middlewares,
            )

    form_data = {
        'rule': existing.rule,
        'service': existing.service,
        'entrypoints': existing.entrypoints,
        'middlewares': existing.middlewares,
        'enable_tls': bool(existing.tls),
        'cert_resolver': _tls_cert_resolver_value(existing.tls) if existing.tls else '',
        'tls_options': existing.tls.options if existing.tls else '',
        'priority': existing.priority,
        'tls_passthrough': existing.tls_passthrough,
    }
    return render_template(
        'tcp/edit_tcp_router.html',
        router=existing,
        form_data=form_data,
        tcp_services=tcp_services,
        tcp_middlewares=tcp_middlewares,
        tls_options=tls_options,
        cert_resolvers=cert_resolvers,
        entrypoint_options=TCP_ENTRYPOINT_OPTIONS,
        selected_entrypoints=existing.entrypoints,
        selected_middlewares=existing.middlewares,
    )


# ============================================================
# TCP Service Management
# ============================================================

@app.route('/tcp/services')
def list_tcp_services():
    """List all TCP services."""
    try:
        names = config_manager.list_tcp_services()
        return render_template('tcp/tcp_services.html', services=names)
    except Exception as e:
        flash(f'Error loading TCP services: {str(e)}', 'danger')
        return render_template('tcp/tcp_services.html', services=[])


@app.route('/tcp/services/create', methods=['GET', 'POST'])
def create_tcp_service():
    """Create a TCP service."""
    if request.method == 'POST':
        name = request.form.get('name', '').strip()
        addresses = _parse_csv(request.form.get('addresses', ''))

        if not name or not addresses:
            flash('Name and at least one server address are required.', 'danger')
            return render_template('tcp/create_tcp_service.html', form_data=request.form)

        try:
            servers = [TCPServer(address=addr) for addr in addresses]
            service = TCPService(name=name, servers=servers)
            config_manager.create_tcp_service(service)
            flash(f'TCP Service "{name}" created!', 'success')
            return redirect(url_for('list_tcp_services'))
        except Exception as e:
            flash(f'Error: {str(e)}', 'danger')
            return render_template('tcp/create_tcp_service.html', form_data=request.form)

    return render_template('tcp/create_tcp_service.html', form_data={})


@app.route('/tcp/services/delete/<name>', methods=['POST'])
@login_required
def delete_tcp_service(name):
    """Delete a TCP service — blocked if referenced by any TCP router."""
    try:
        router_names = config_manager.list_tcp_routers()
        in_use = []
        for rname in router_names:
            r = config_manager.get_tcp_router(rname)
            svc = r.service if hasattr(r, 'service') else (r.get('service', '') if isinstance(r, dict) else '')
            if svc == name:
                in_use.append(rname)
        if in_use:
            in_use_str = ', '.join(in_use)
            flash(f'Cannot delete: TCP service "{name}" is in use by TCP router(s): {in_use_str}', 'danger')
            return redirect(url_for('list_tcp_services'))
        config_manager.delete_tcp_service(name)
        flash(f'TCP Service "{name}" deleted.', 'success')
    except Exception as e:
        flash(f'Error: {str(e)}', 'danger')
    return redirect(url_for('list_tcp_services'))


@app.route('/tcp/services/edit/<name>', methods=['GET', 'POST'])
def edit_tcp_service(name):
    """Edit an existing TCP service."""
    existing = config_manager.get_tcp_service(name)
    if not existing:
        flash(f'TCP Service "{name}" not found.', 'warning')
        return redirect(url_for('list_tcp_services'))

    if request.method == 'POST':
        addresses = _parse_csv(request.form.get('addresses', ''))
        if not addresses:
            flash('At least one server address is required.', 'danger')
            return render_template('tcp/edit_tcp_service.html', service_name=name, form_data=request.form)

        try:
            servers = [TCPServer(address=addr) for addr in addresses]
            service = TCPService(name=name, servers=servers)
            config_manager.update_tcp_service(service)
            flash(f'TCP Service "{name}" updated!', 'success')
            return redirect(url_for('list_tcp_services'))
        except Exception as e:
            flash(f'Error: {str(e)}', 'danger')
            return render_template('tcp/edit_tcp_service.html', service_name=name, form_data=request.form)

    addresses_str = ', '.join(s.address for s in existing.servers) if existing.servers else ''
    return render_template('tcp/edit_tcp_service.html', service_name=name, form_data={'addresses': addresses_str})


# ============================================================
# TCP Middleware Management
# ============================================================

@app.route('/tcp/middlewares')
def list_tcp_middlewares():
    """List all TCP middlewares."""
    try:
        names = config_manager.list_tcp_middlewares()
        return render_template('tcp/tcp_middlewares.html', middlewares=names)
    except Exception as e:
        flash(f'Error: {str(e)}', 'danger')
        return render_template('tcp/tcp_middlewares.html', middlewares=[])


@app.route('/tcp/middlewares/create', methods=['GET', 'POST'])
def create_tcp_middleware():
    """Create a TCP middleware (inFlightConn or ipAllowList)."""
    if request.method == 'POST':
        name = request.form.get('name', '').strip()
        mw_type = request.form.get('middleware_type', '').strip()

        if not name or not mw_type:
            flash('Name and type are required.', 'danger')
            return render_template('tcp/create_tcp_middleware.html', form_data=request.form)

        try:
            if mw_type == 'inFlightConn':
                amount = _parse_int(request.form.get('amount', '10'), 10)
                config_manager.create_tcp_middleware(name, TCPMiddlewareType.IN_FLIGHT_CONN, {'amount': amount})
            elif mw_type == 'ipAllowList':
                source_range = _parse_csv(request.form.get('source_range', ''))
                config_manager.create_tcp_middleware(name, TCPMiddlewareType.IP_ALLOW_LIST, {'sourceRange': source_range})
            else:
                flash('Unknown TCP middleware type.', 'danger')
                return render_template('tcp/create_tcp_middleware.html', form_data=request.form)

            flash(f'TCP Middleware "{name}" created!', 'success')
            return redirect(url_for('list_tcp_middlewares'))
        except Exception as e:
            flash(f'Error: {str(e)}', 'danger')
            return render_template('tcp/create_tcp_middleware.html', form_data=request.form)

    return render_template('tcp/create_tcp_middleware.html', form_data={})


@app.route('/tcp/middlewares/delete/<name>', methods=['POST'])
@login_required
def delete_tcp_middleware(name):
    """Delete a TCP middleware — blocked if referenced by any TCP router."""
    try:
        router_names = config_manager.list_tcp_routers()
        in_use = []
        for rname in router_names:
            r = config_manager.get_tcp_router(rname)
            mws = r.middlewares if hasattr(r, 'middlewares') else (r.get('middlewares', []) if isinstance(r, dict) else [])
            if name in (mws or []):
                in_use.append(rname)
        if in_use:
            in_use_str = ', '.join(in_use)
            flash(f'Cannot delete: TCP middleware "{name}" is in use by TCP router(s): {in_use_str}', 'danger')
            return redirect(url_for('list_tcp_middlewares'))
        config_manager.delete_tcp_middleware(name)
        flash(f'TCP Middleware "{name}" deleted.', 'success')
    except Exception as e:
        flash(f'Error: {str(e)}', 'danger')
    return redirect(url_for('list_tcp_middlewares'))


@app.route('/tcp/middlewares/edit/<name>', methods=['GET', 'POST'])
def edit_tcp_middleware(name):
    """Edit an existing TCP middleware."""
    existing_data = config_manager.get_tcp_middleware(name)
    if not existing_data:
        flash(f'TCP Middleware "{name}" not found.', 'warning')
        return redirect(url_for('list_tcp_middlewares'))

    mw_type_obj, mw_config = existing_data

    if request.method == 'POST':
        mw_type = request.form.get('middleware_type', '').strip()
        try:
            if mw_type == 'inFlightConn':
                amount = _parse_int(request.form.get('amount', '10'), 10)
                config_manager.create_tcp_middleware(name, TCPMiddlewareType.IN_FLIGHT_CONN, {'amount': amount})
            elif mw_type == 'ipAllowList':
                source_range = _parse_csv(request.form.get('source_range', ''))
                config_manager.create_tcp_middleware(name, TCPMiddlewareType.IP_ALLOW_LIST, {'sourceRange': source_range})
            else:
                flash('Unknown TCP middleware type.', 'danger')
                return render_template('tcp/edit_tcp_middleware.html', mw_name=name, form_data=request.form,
                                       mw_type=mw_type_obj.value, mw_config=mw_config)
            flash(f'TCP Middleware "{name}" updated!', 'success')
            return redirect(url_for('list_tcp_middlewares'))
        except Exception as e:
            flash(f'Error: {str(e)}', 'danger')
            return render_template('tcp/edit_tcp_middleware.html', mw_name=name, form_data=request.form,
                                   mw_type=mw_type_obj.value, mw_config=mw_config)

    return render_template('tcp/edit_tcp_middleware.html', mw_name=name, form_data={},
                           mw_type=mw_type_obj.value, mw_config=mw_config)


