@app.route('/tls/options')
def list_tls_options():
    """List all TLS option sets."""
    try:
        names = config_manager.list_tls_options()
        options_list = []
        for name in names:
            o = config_manager.get_tls_options(name)
            options_list.append(o if o else TLSOptions(name=name))
        return render_template('tls/tls_options.html', options_list=options_list)
    except Exception as e:
        flash(f'Error: {str(e)}', 'danger')
        return render_template('tls/tls_options.html', options_list=[])


@app.route('/tls/options/create', methods=['GET', 'POST'])
def create_tls_options():
    """Create a TLS options set."""
    if request.method == 'POST':
        name = request.form.get('name', '').strip()
        min_version = request.form.get('min_version', '').strip()
        max_version = request.form.get('max_version', '').strip()
        cipher_suites = _parse_csv(request.form.get('cipher_suites', ''))
        curve_preferences = _parse_csv(request.form.get('curve_preferences', ''))
        sni_strict = request.form.get('sni_strict') == 'on'
        alpn_protocols = _parse_csv(request.form.get('alpn_protocols', ''))
        client_auth_type = request.form.get('client_auth_type', '').strip()
        client_auth_ca_files = _parse_csv(request.form.get('client_auth_ca_files', ''))

        if not name:
            flash('Name is required.', 'danger')
            return render_template('tls/create_tls_options.html', form_data=request.form)

        try:
            opts = TLSOptions(
                name=name, min_version=min_version, max_version=max_version,
                cipher_suites=cipher_suites, curve_preferences=curve_preferences,
                sni_strict=sni_strict, alpn_protocols=alpn_protocols,
                client_auth_type=client_auth_type, client_auth_ca_files=client_auth_ca_files,
            )
            config_manager.create_tls_options(opts)
            flash(f'TLS Options "{name}" created!', 'success')
            return redirect(url_for('list_tls_options'))
        except Exception as e:
            flash(f'Error: {str(e)}', 'danger')
            return render_template('tls/create_tls_options.html', form_data=request.form)

    return render_template('tls/create_tls_options.html', form_data={})


@app.route('/tls/options/delete/<name>', methods=['POST'])
def delete_tls_options(name):
    """Delete a TLS options set."""
    try:
        config_manager.delete_tls_options(name)
        flash(f'TLS Options "{name}" deleted.', 'success')
    except Exception as e:
        flash(f'Error: {str(e)}', 'danger')
    return redirect(url_for('list_tls_options'))


@app.route('/tls/options/edit/<name>', methods=['GET', 'POST'])
def edit_tls_options(name):
    """Edit an existing TLS options set."""
    existing = config_manager.get_tls_options(name)
    if not existing:
        flash(f'TLS Options "{name}" not found.', 'warning')
        return redirect(url_for('list_tls_options'))

    if request.method == 'POST':
        min_version = request.form.get('min_version', '').strip()
        max_version = request.form.get('max_version', '').strip()
        cipher_suites = _parse_csv(request.form.get('cipher_suites', ''))
        curve_preferences = _parse_csv(request.form.get('curve_preferences', ''))
        sni_strict = request.form.get('sni_strict') == 'on'
        alpn_protocols = _parse_csv(request.form.get('alpn_protocols', ''))
        client_auth_type = request.form.get('client_auth_type', '').strip()
        client_auth_ca_files = _parse_csv(request.form.get('client_auth_ca_files', ''))

        try:
            opts = TLSOptions(
                name=name, min_version=min_version, max_version=max_version,
                cipher_suites=cipher_suites, curve_preferences=curve_preferences,
                sni_strict=sni_strict, alpn_protocols=alpn_protocols,
                client_auth_type=client_auth_type, client_auth_ca_files=client_auth_ca_files,
            )
            config_manager.update_tls_options(opts)
            flash(f'TLS Options "{name}" updated!', 'success')
            return redirect(url_for('list_tls_options'))
        except Exception as e:
            flash(f'Error: {str(e)}', 'danger')
            return render_template('tls/edit_tls_options.html', opts_name=name, form_data=request.form)

    form_data = {
        'min_version': existing.min_version,
        'max_version': existing.max_version,
        'cipher_suites': ', '.join(existing.cipher_suites),
        'curve_preferences': ', '.join(existing.curve_preferences),
        'sni_strict': existing.sni_strict,
        'alpn_protocols': ', '.join(existing.alpn_protocols),
        'client_auth_type': existing.client_auth_type,
        'client_auth_ca_files': ', '.join(existing.client_auth_ca_files),
    }
    return render_template('tls/edit_tls_options.html', opts_name=name, form_data=form_data)


