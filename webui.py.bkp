# TLS Store Management
# ============================================================

@app.route('/tls/stores')
def list_tls_stores():
    """List all TLS stores."""
    try:
        names = config_manager.list_tls_stores()
        stores = []
        for name in names:
            s = config_manager.get_tls_store(name)
            stores.append(s if s else TLSStore(name=name))
        return render_template('tls/tls_stores.html', stores=stores)
    except Exception as e:
        flash(f'Error: {str(e)}', 'danger')
        return render_template('tls/tls_stores.html', stores=[])


@app.route('/tls/stores/create', methods=['GET', 'POST'])
def create_tls_store():
    """Create a TLS store."""
    if request.method == 'POST':
        name = request.form.get('name', '').strip()
        cert_file = request.form.get('cert_file', '').strip()
        key_file = request.form.get('key_file', '').strip()
        gen_resolver = request.form.get('gen_resolver', '').strip()
        gen_domain_main = request.form.get('gen_domain_main', '').strip()
        gen_domain_sans = _parse_csv(request.form.get('gen_domain_sans', ''))

        if not name:
            flash('Name is required.', 'danger')
            return render_template('tls/create_tls_store.html', form_data=request.form)

        try:
            store = TLSStore(
                name=name,
                default_certificate_cert=cert_file,
                default_certificate_key=key_file,
                default_generated_cert_resolver=gen_resolver,
                default_generated_cert_domain_main=gen_domain_main,
                default_generated_cert_domain_sans=gen_domain_sans,
            )
            config_manager.create_tls_store(store)
            flash(f'TLS Store "{name}" created!', 'success')
            return redirect(url_for('list_tls_stores'))
        except Exception as e:
            flash(f'Error: {str(e)}', 'danger')
            return render_template('tls/create_tls_store.html', form_data=request.form)

    return render_template('tls/create_tls_store.html', form_data={})


@app.route('/tls/stores/delete/<name>', methods=['POST'])
def delete_tls_store(name):
    """Delete a TLS store."""
    try:
        config_manager.delete_tls_store(name)
        flash(f'TLS Store "{name}" deleted.', 'success')
    except Exception as e:
        flash(f'Error: {str(e)}', 'danger')
    return redirect(url_for('list_tls_stores'))


@app.route('/tls/stores/edit/<name>', methods=['GET', 'POST'])
def edit_tls_store(name):
    """Edit an existing TLS store."""
    existing = config_manager.get_tls_store(name)
    if not existing:
        flash(f'TLS Store "{name}" not found.', 'warning')
        return redirect(url_for('list_tls_stores'))

    if request.method == 'POST':
        cert_file = request.form.get('cert_file', '').strip()
        key_file = request.form.get('key_file', '').strip()
        gen_resolver = request.form.get('gen_resolver', '').strip()
        gen_domain_main = request.form.get('gen_domain_main', '').strip()
        gen_domain_sans = _parse_csv(request.form.get('gen_domain_sans', ''))

        try:
            store = TLSStore(
                name=name,
                default_certificate_cert=cert_file,
                default_certificate_key=key_file,
                default_generated_cert_resolver=gen_resolver,
                default_generated_cert_domain_main=gen_domain_main,
                default_generated_cert_domain_sans=gen_domain_sans,
            )
            config_manager.update_tls_store(store)
            flash(f'TLS Store "{name}" updated!', 'success')
            return redirect(url_for('list_tls_stores'))
        except Exception as e:
            flash(f'Error: {str(e)}', 'danger')
            return render_template('tls/edit_tls_store.html', store_name=name, form_data=request.form)

    form_data = {
        'cert_file': existing.default_certificate_cert,
        'key_file': existing.default_certificate_key,
        'gen_resolver': existing.default_generated_cert_resolver,
        'gen_domain_main': existing.default_generated_cert_domain_main,
        'gen_domain_sans': ', '.join(existing.default_generated_cert_domain_sans),
    }
    return render_template('tls/edit_tls_store.html', store_name=name, form_data=form_data)


